---
import Container from '@components/Container.astro';
import Button from '@components/Button.astro';
import { footerNav, legalNav } from '@data/nav';
import { cta } from '@data/cta';

const year = new Date().getFullYear();
---

<footer class="border-line bg-surface border-t">
  <Container class="py-14 lg:py-20">
    <!-- Final CTA band -->
    <div
      class="surface-dark border-night-600 relative mb-14 flex flex-col items-start justify-between gap-6 overflow-hidden rounded-3xl border px-7 py-12 sm:px-10 lg:flex-row lg:items-center"
    >
      <div class="dot-grid-dark pointer-events-none absolute inset-0 opacity-50" aria-hidden="true">
      </div>
      <div class="relative">
        <h2 class="text-2xl font-bold sm:text-3xl">
          Data driven success <span class="text-gradient-bright">starts today</span>
        </h2>
        <p class="mt-2 max-w-xl text-white/65">
          Working with us is not a cost. It's an investment. Let's turn your data into sales.
        </p>
      </div>
      <Button href={cta.becomeClient.href} external variant="primary" size="lg" class="relative">
        {cta.becomeClient.label}
      </Button>
    </div>

    <div class="flex flex-col gap-10 sm:flex-row sm:justify-between">
      <div class="max-w-sm">
        <a href="/" class="flex items-center" aria-label="Agora Data Driven">
          <img src="/agora-logo.png" alt="Agora Data Driven" class="h-9 w-auto" />
        </a>
        <p class="text-muted mt-3 text-sm">
          Analytics-powered marketing for real results. We turn insights into sales.
        </p>
      </div>

      <nav aria-label="Footer">
        <h3 class="text-ink text-sm font-semibold tracking-wide uppercase">Pages</h3>
        <ul class="mt-3 space-y-2">
          {
            footerNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-muted hover:text-brand-600 text-sm transition-colors"
                  rel={item.external ? 'noopener noreferrer' : undefined}
                  target={item.external ? '_blank' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="border-line text-muted mt-12 flex flex-col gap-3 border-t pt-6 text-sm sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} Agora Data Driven. All rights reserved.</p>
      <ul class="flex gap-5">
        {
          legalNav.map((item) => (
            <li>
              <a href={item.href} class="hover:text-brand-600 transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</footer>
