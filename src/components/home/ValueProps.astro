---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import HeroViz from '@components/home/HeroViz.astro';

// "What working with us looks like": a large autoplaying, looping, muted video
// on the left (plays on its own, no controls) and a clean, vertically-centered
// list of value props on the right that reveal with a soft stagger.
const props = [
  {
    title: 'Actionable insights, not just reports',
    body: 'We translate data into clear decisions and next steps that move marketing performance, not dashboards that gather dust.',
    icon: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5"/>',
  },
  {
    title: 'Deep technical expertise',
    body: 'Hands-on with data, social, and eCommerce analytics: Looker Studio, Google Colab, KPI reporting, and machine learning.',
    icon: '<rect x="5" y="5" width="14" height="14" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/>',
  },
  {
    title: 'Clear communication',
    body: 'You always know what we are doing and why. We move quickly and keep collaboration simple.',
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>',
  },
  {
    title: 'Tailored to your goals',
    body: 'Solutions built around your business objectives and timeline, flexible for short-term sprints or long-term partnerships.',
    icon: '<line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/><circle cx="9" cy="6" r="2.2" fill="var(--color-surface)"/><circle cx="15" cy="12" r="2.2" fill="var(--color-surface)"/><circle cx="8" cy="18" r="2.2" fill="var(--color-surface)"/>',
  },
];
---

<section class="border-line border-b py-16 lg:py-24">
  <Container>
    <SectionHeading eyebrow="Why Agora" title="What working with us looks like" class="reveal">
      <p class="text-muted mt-3">
        The strength of a data team, with the clarity and pace of a partner who actually answers.
      </p>
    </SectionHeading>

    <div class="mt-14 grid items-center gap-10 lg:grid-cols-12 lg:gap-12">
      <!-- Live ML showcase LEFT (7/12): looping canvas that cycles through the
           machine-learning techniques Agora ships. Ambient glow + award chips. -->
      <div class="reveal relative lg:col-span-7">
        <div
          class="glow-pulse bg-brand-300/25 pointer-events-none absolute -inset-6 -z-10 rounded-[2.5rem] blur-3xl"
          aria-hidden="true"
        >
        </div>
        <HeroViz />
        <div
          class="border-line bg-surface shadow-pop absolute -bottom-5 -left-4 hidden rounded-xl border px-4 py-3 sm:block"
        >
          <div class="font-display text-brand-600 text-sm font-bold">2nd / 2,459</div>
          <div class="text-muted text-[0.7rem]">Marketing analytics comp.</div>
        </div>
        <div
          class="border-line bg-surface shadow-pop absolute -top-5 -right-3 hidden rounded-xl border px-4 py-3 md:block"
        >
          <div class="font-display text-accent-600 text-sm font-bold">1st place 🏆</div>
          <div class="text-muted text-[0.7rem]">Operations analytics</div>
        </div>
      </div>

      <!-- Content RIGHT: aligned, vertically centered list with staggered reveal. -->
      <div class="lg:col-span-5">
        <ul class="space-y-7">
          {
            props.map((p, i) => (
              <li class="reveal group flex gap-4" style={`--reveal-delay: ${(i + 1) * 110}ms`}>
                <div class="from-brand-500 to-emerald shadow-glow-sm grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-linear-to-br text-white transition-transform duration-300 group-hover:-translate-y-0.5">
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={p.icon}
                  />
                </div>
                <div>
                  <h3 class="text-ink text-lg font-semibold">{p.title}</h3>
                  <p class="text-muted mt-1.5 text-sm leading-relaxed">{p.body}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</section>
