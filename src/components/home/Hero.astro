---
import Container from '@components/Container.astro';
import Button from '@components/Button.astro';
import HeroViz from '@components/home/HeroViz.astro';
import { cta } from '@data/cta';
---

<section class="relative overflow-hidden border-b border-line">
  <div
    class="pointer-events-none absolute inset-0 bg-grid opacity-60 [mask-image:radial-gradient(ellipse_at_top_left,black,transparent_72%)]"
  >
  </div>
  <div
    class="pointer-events-none absolute -top-40 -right-32 h-[34rem] w-[34rem] rounded-full bg-brand-300/25 blur-[130px]"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-36 left-1/4 h-[22rem] w-[22rem] rounded-full bg-accent-300/15 blur-[120px]"
  >
  </div>

  <Container class="relative py-20 lg:py-28">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <!-- Copy -->
      <div>
        <p class="eyebrow">Data-driven marketing &amp; analytics</p>
        <h1 class="mt-6 text-4xl leading-[1.05] font-bold text-ink sm:text-5xl lg:text-6xl">
          Analytics powered marketing for
          <span class="sr-only">real results.</span>
          <span class="mt-2 block text-brand-600" aria-hidden="true">
            <span id="hero-rotator">real results</span><span class="hero-caret"></span>
          </span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-muted">
          We turn insights into sales. From strategy to execution, we help you scale, optimize, and
          make smarter decisions—faster. Working with us isn't a cost; it's an investment.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <Button href={cta.becomeClient.href} external size="lg">{cta.becomeClient.label}</Button>
          <Button href={cta.customQuote.href} external variant="secondary" size="lg">
            {cta.customQuote.label}
          </Button>
        </div>

        <div class="mt-8 flex items-center gap-3 text-sm text-muted">
          <span class="tracking-tight text-brand-500" aria-hidden="true">★★★★★</span>
          <span><span class="font-semibold text-ink">Top Rated</span> agency on Upwork</span>
        </div>
      </div>

      <!-- Live ML showcase -->
      <div class="relative">
        <HeroViz />
        <div
          class="absolute -bottom-5 -left-4 hidden rounded-xl border border-line bg-surface px-4 py-3 shadow-card sm:block"
        >
          <div class="font-display text-sm font-bold text-accent-600">2nd / 2,459</div>
          <div class="text-[0.7rem] text-muted">Marketing analytics comp.</div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-caret {
    display: inline-block;
    width: 0.5ch;
    height: 1em;
    margin-left: 0.1em;
    background: currentColor;
    vertical-align: -0.08em;
    animation: hero-blink 1.05s step-end infinite;
  }
  @keyframes hero-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-caret {
      animation: none;
    }
  }
</style>

<script>
  const el = document.getElementById('hero-rotator');
  if (el) {
    const words = ['real results', 'real growth', 'more sales', 'real change', 'real progress'];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      el.textContent = words[0];
    } else {
      let w = 0;
      let c = words[0].length;
      let deleting = true;
      const tick = () => {
        const word = words[w];
        if (!deleting) {
          c++;
          el.textContent = word.slice(0, c);
          if (c === word.length) {
            deleting = true;
            setTimeout(tick, 1500);
            return;
          }
          setTimeout(tick, 75);
        } else {
          c--;
          el.textContent = word.slice(0, Math.max(c, 0));
          if (c <= 0) {
            deleting = false;
            w = (w + 1) % words.length;
            setTimeout(tick, 260);
            return;
          }
          setTimeout(tick, 38);
        }
      };
      setTimeout(tick, 1600);
    }
  }
</script>
