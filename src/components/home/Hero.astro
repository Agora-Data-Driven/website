---
import Container from '@components/Container.astro';
import Button from '@components/Button.astro';
import HeroViz from '@components/home/HeroViz.astro';
import { cta } from '@data/cta';
---

<section class="border-line relative overflow-hidden border-b">
  <div
    class="bg-grid pointer-events-none absolute inset-0 [mask-image:radial-gradient(ellipse_at_top_left,black,transparent_72%)] opacity-60"
  >
  </div>
  <div
    class="glow-pulse bg-brand-300/30 pointer-events-none absolute -top-40 -right-32 h-[34rem] w-[34rem] rounded-full blur-[130px]"
  >
  </div>
  <div
    class="glow-pulse bg-accent-300/20 pointer-events-none absolute -bottom-36 left-1/4 h-[22rem] w-[22rem] rounded-full blur-[120px]"
    style="animation-delay: -4.5s"
  >
  </div>

  <Container class="relative py-20 lg:py-28">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <!-- Copy -->
      <div>
        <p
          class="reveal border-brand-200 bg-tint/70 text-brand-700 inline-flex items-center gap-2 rounded-full border py-1.5 pr-4 pl-2.5 text-xs font-semibold tracking-wide uppercase backdrop-blur"
        >
          <span
            class="bg-brand-500 grid h-4 w-4 place-items-center rounded-full"
            aria-hidden="true"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
          </span>
          Data-driven marketing &amp; analytics
        </p>
        <h1
          class="reveal text-ink mt-6 text-4xl leading-[1.04] font-bold sm:text-5xl lg:text-[4rem]"
          style="--reveal-delay: 80ms"
        >
          Analytics powered marketing for
          <span class="sr-only">real results.</span>
          <span class="mt-2 block" aria-hidden="true">
            <span id="hero-rotator" class="text-gradient">real results</span><span
              class="hero-caret"></span>
          </span>
        </h1>
        <p class="reveal text-muted mt-6 max-w-xl text-lg" style="--reveal-delay: 160ms">
          We turn insights into sales. From strategy to execution, we help you scale, optimize, and
          make smarter decisions, faster. Working with us isn't a cost; it's an investment.
        </p>

        <div class="reveal mt-8 flex flex-wrap gap-4" style="--reveal-delay: 240ms">
          <Button href={cta.becomeClient.href} external size="lg">{cta.becomeClient.label}</Button>
          <Button href={cta.customQuote.href} external variant="secondary" size="lg">
            {cta.customQuote.label}
          </Button>
        </div>

        <div
          class="reveal text-muted mt-9 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm"
          style="--reveal-delay: 320ms"
        >
          <span class="flex items-center gap-2">
            <span class="text-brand-500 tracking-tight" aria-hidden="true">★★★★★</span>
            <span><span class="text-ink font-semibold">Top Rated</span> on Upwork</span>
          </span>
          <span class="bg-line hidden h-4 w-px sm:block" aria-hidden="true"></span>
          <span class="flex items-center gap-2">
            <span class="font-display text-ink font-bold">9</span> verifiable certifications
          </span>
          <span class="bg-line hidden h-4 w-px sm:block" aria-hidden="true"></span>
          <span class="flex items-center gap-2">
            <span class="font-display text-ink font-bold">2×</span> award-winning analytics
          </span>
        </div>
      </div>

      <!-- Live ML showcase -->
      <div class="reveal relative" style="--reveal-delay: 200ms">
        <div
          class="glow-pulse bg-brand-300/25 pointer-events-none absolute -inset-6 -z-10 rounded-[2.5rem] blur-3xl"
        >
        </div>
        <HeroViz />
        <div
          class="border-line bg-surface shadow-pop absolute -bottom-5 -left-4 hidden rounded-xl border px-4 py-3 sm:block"
        >
          <div class="font-display text-brand-600 text-sm font-bold">2nd / 2,459</div>
          <div class="text-muted text-[0.7rem]">Marketing analytics comp.</div>
        </div>
        <div
          class="border-line bg-surface shadow-pop absolute -top-5 -right-3 hidden rounded-xl border px-4 py-3 md:block"
        >
          <div class="font-display text-accent-600 text-sm font-bold">1st place 🏆</div>
          <div class="text-muted text-[0.7rem]">Operations analytics</div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-caret {
    display: inline-block;
    width: 0.5ch;
    height: 1em;
    margin-left: 0.1em;
    background: currentColor;
    vertical-align: -0.08em;
    animation: hero-blink 1.05s step-end infinite;
  }
  @keyframes hero-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-caret {
      animation: none;
    }
  }
</style>

<script>
  const el = document.getElementById('hero-rotator');
  if (el) {
    const words = ['real results', 'real growth', 'more sales', 'real change', 'real progress'];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      el.textContent = words[0];
    } else {
      let w = 0;
      let c = words[0].length;
      let deleting = true;
      const tick = () => {
        const word = words[w];
        if (!deleting) {
          c++;
          el.textContent = word.slice(0, c);
          if (c === word.length) {
            deleting = true;
            setTimeout(tick, 1500);
            return;
          }
          setTimeout(tick, 75);
        } else {
          c--;
          el.textContent = word.slice(0, Math.max(c, 0));
          if (c <= 0) {
            deleting = false;
            w = (w + 1) % words.length;
            setTimeout(tick, 260);
            return;
          }
          setTimeout(tick, 38);
        }
      };
      setTimeout(tick, 1600);
    }
  }
</script>
