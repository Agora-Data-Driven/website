---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { certifications } from '@data/certifications';

// Render the list twice for a seamless marquee loop; the second copy is hidden
// from assistive tech and keyboard focus so the badges aren't announced twice.
const loop = [...certifications, ...certifications];
const realCount = certifications.length;
---

<section class="border-line bg-surface overflow-hidden border-b py-16 lg:py-20">
  <Container>
    <SectionHeading eyebrow="Certified expertise" title="Credentials you can verify" align="center">
      <p class="text-muted mt-3">
        Real, verifiable certifications in data science, analytics, and media buying, from IBM,
        Google, Meta, and Intuit.
      </p>
    </SectionHeading>
  </Container>

  <!-- Marquee: slow, seamless, infinite. Pauses on hover/focus; falls back to a
       static, wrapped row when the visitor prefers reduced motion. -->
  <div class="marquee reveal relative mt-12" aria-label="Verifiable professional certifications">
    <div
      class="from-surface pointer-events-none absolute inset-y-0 left-0 z-10 w-12 bg-linear-to-r to-transparent sm:w-24"
    >
    </div>
    <div
      class="from-surface pointer-events-none absolute inset-y-0 right-0 z-10 w-12 bg-linear-to-l to-transparent sm:w-24"
    >
    </div>

    <div class="marquee-track flex w-max gap-4 px-5 sm:gap-6 sm:px-6">
      {
        loop.map((c, i) => {
          const dup = i >= realCount;
          const Tag = c.url ? 'a' : 'div';
          return (
            <Tag
              class="group border-line bg-surface hover:border-brand-300 hover:shadow-card flex w-40 shrink-0 flex-col items-center justify-center gap-3 rounded-2xl border p-5 text-center transition-[box-shadow,border-color] duration-300 sm:w-44"
              href={c.url}
              target={c.url ? '_blank' : undefined}
              rel={c.url ? 'noopener noreferrer' : undefined}
              aria-hidden={dup ? 'true' : undefined}
              tabindex={dup ? -1 : undefined}
            >
              <img
                src={c.image}
                alt={dup ? '' : `${c.name} certification badge`}
                width="200"
                height="200"
                loading="lazy"
                decoding="async"
                draggable="false"
                class="pointer-events-none h-24 w-auto object-contain transition-transform duration-300 group-hover:scale-105 sm:h-28"
              />
              <span class="text-muted text-xs font-medium">{c.name}</span>
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .marquee {
    /* Soften both edges so badges fade in/out rather than hard-clipping. */
    -webkit-mask-image: linear-gradient(to right, transparent, #000 4%, #000 96%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 4%, #000 96%, transparent);
  }

  .marquee-track {
    /* Track holds two identical copies, so translating by -50% lands exactly on
       the start of the second copy, a seamless, jump-free loop. */
    animation: marquee-scroll 60s linear infinite;
    will-change: transform;
  }

  /* Pause when the visitor hovers or keyboard-focuses anything inside. */
  .marquee:hover .marquee-track,
  .marquee:focus-within .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      -webkit-mask-image: none;
      mask-image: none;
    }
    /* Static, centered, wrapped row, no animation. */
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
      justify-content: center;
    }
  }
</style>
