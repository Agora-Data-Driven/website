---
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { certifications } from '@data/certifications';
---

<section class="border-b border-line bg-surface py-16 lg:py-20">
  <Container>
    <SectionHeading eyebrow="Certified expertise" title="Credentials you can verify" align="center">
      <p class="mt-3 text-muted">
        Real, verifiable certifications in data science, analytics, and media buying — from IBM,
        Google, Meta, and Intuit.
      </p>
    </SectionHeading>

    <ul class="mx-auto mt-12 grid max-w-4xl grid-cols-2 gap-4 sm:grid-cols-3 sm:gap-6">
      {
        certifications.map((c) => {
          const Tag = c.url ? 'a' : 'div';
          return (
            <li>
              <Tag
                class="group flex h-full flex-col items-center justify-center gap-3 rounded-2xl border border-line bg-surface p-5 text-center transition-shadow hover:shadow-card"
                href={c.url}
                target={c.url ? '_blank' : undefined}
                rel={c.url ? 'noopener noreferrer' : undefined}
              >
                <img
                  src={c.image}
                  alt={`${c.name} certification badge`}
                  width="200"
                  height="200"
                  loading="lazy"
                  decoding="async"
                  class="h-24 w-auto object-contain transition-transform duration-200 group-hover:scale-105 sm:h-28"
                />
                <span class="text-xs font-medium text-muted">{c.name}</span>
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </Container>
</section>
