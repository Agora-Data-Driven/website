---
/**
 * PageAurora — the drifting green light field that sits behind an entire page
 * (every band, not just the hero). Five blurred blobs on long, offset
 * ease-in-out loops so the field never visibly repeats or "pumps".
 *
 * It paints at `z-index:-1` (fixed to the viewport), i.e. above the root
 * background and below all content, so no ancestor needs a stacking context —
 * but any section that wants it visible must not set an opaque background.
 *
 * `variant="soft"` halves the intensity for long-form reading surfaces, where
 * body copy has to keep its AA contrast against the canvas.
 */
interface Props {
  variant?: 'default' | 'soft';
}
const { variant = 'default' } = Astro.props;
---

<div class:list={['page-aurora', variant === 'soft' && 'page-aurora--soft']} aria-hidden="true">
  <div class="aurora__blob aurora__blob--1"></div>
  <div class="aurora__blob aurora__blob--2"></div>
  <div class="aurora__blob aurora__blob--3"></div>
  <div class="aurora__blob aurora__blob--4"></div>
  <div class="aurora__blob aurora__blob--5"></div>
</div>
