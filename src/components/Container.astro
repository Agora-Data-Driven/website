---
interface Props {
  as?: string;
  size?: 'narrow' | 'default' | 'wide';
  class?: string;
}
const { as = 'div', size = 'default', class: className = '' } = Astro.props;
const Tag = as as keyof HTMLElementTagNameMap;
const maxBySize: Record<string, string> = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
};
const max = maxBySize[size];
---

<Tag class={`mx-auto w-full ${max} px-5 sm:px-6 lg:px-8 ${className}`}>
  <slot />
</Tag>
