      <rect x="408" y="136" width="168" height="28" rx="6" fill="#f7f7f8" stroke="#e6e6e9" stroke-width="1" />
      <circle cx="424" cy="150" r="5" fill="#4fa84a" />
      <rect x="436" y="147" width="80" height="6" rx="3" fill="#e6e6e9" />
      <rect x="408" y="172" width="168" height="28" rx="6" fill="#f7f7f8" stroke="#e6e6e9" stroke-width="1" />
      <circle cx="424" cy="186" r="5" fill="#bee0bc" />
