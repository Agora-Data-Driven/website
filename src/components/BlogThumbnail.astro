      <rect x="248" y="60" width="144" height="52" rx="10" fill="#eef6ed" />
      <rect x="264" y="80" width="112" height="10" rx="5" fill="#94cd91" />
      <rect x="264" y="97" width="84" height="5" rx="2.5" fill="#bee0bc" />
      <rect x="264" y="126" width="112" height="6" rx="3" fill="#e6e6e9" />
      <rect x="264" y="138" width="92" height="6" rx="3" fill="#e6e6e9" />
      <rect x="264" y="150" width="104" height="6" rx="3" fill="#e6e6e9" />
      <rect x="264" y="162" width="80" height="6" rx="3" fill="#e6e6e9" />
      <rect x="264" y="196" width="64" height="18" rx="9" fill="#4fa84a" />
      {/* Winner crown/badge */}
      <circle cx="320" cy="56" r="14" fill="#4fa84a" />
      <path d="M313 60 L316 54 L320 59 L324 54 L327 60 Z" fill="#fff" />
      {/* Label B */}
      <circle cx="320" cy="270" r="16" fill="#4fa84a" />
      <rect x="304" y="281" width="32" height="4" rx="2" fill="#4fa84a" />
      {/* Card C */}
      <rect x="426" y="80" width="142" height="156" rx="12" fill="#fff" stroke="#e6e6e9" stroke-width="1.5" />
      <rect x="426" y="80" width="142" height="48" rx="10" fill="#f1f8f0" />
      <rect x="442" y="100" width="110" height="10" rx="5" fill="#e6e6e9" />
      <rect x="442" y="116" width="80" height="5" rx="2.5" fill="#bee0bc" />
      <rect x="442" y="142" width="110" height="6" rx="3" fill="#e6e6e9" />
      <rect x="442" y="154" width="90" height="6" rx="3" fill="#e6e6e9" />
      <rect x="442" y="166" width="100" height="6" rx="3" fill="#e6e6e9" />
      <rect x="442" y="204" width="60" height="16" rx="8" fill="#e6e6e9" />
      {/* Label C */}
      <circle cx="497" cy="260" r="16" fill="#e6e6e9" />
      <rect x="481" y="271" width="32" height="4" rx="2" fill="#e6e6e9" />
      {/* Result bars */}
      <rect x="97" y="310" width="32" height="22" rx="4" fill="#e6e6e9" />
      <rect x="304" y="298" width="32" height="34" rx="4" fill="#4fa84a" />
      <rect x="481" y="314" width="32" height="18" rx="4" fill="#e6e6e9" />
    </svg>
  )
}

{
  variant === 'channel-launch' && (
    <svg viewBox="0 0 640 360" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class={className}>
      <rect width="640" height="360" fill="#f7f7f8" />
      {/* Ad/search interface panel */}
      <rect x="48" y="88" width="220" height="184" rx="16" fill="#fff" stroke="#e6e6e9" stroke-width="1.5" />
      {/* Search bar */}
      <rect x="64" y="108" width="188" height="32" rx="8" fill="#f7f7f8" stroke="#e6e6e9" stroke-width="1" />
      <circle cx="84" cy="124" r="6" fill="none" stroke="#6b6f6c" stroke-width="1.5" />
      <line x1="88" y1="128" x2="93" y2="133" stroke="#6b6f6c" stroke-width="1.5" stroke-linecap="round" />
      <rect x="100" y="120" width="100" height="8" rx="4" fill="#e6e6e9" />
      {/* Ad result rows */}
      <rect x="64" y="156" width="188" height="28" rx="6" fill="#eef6ed" stroke="#bee0bc" stroke-width="1" />
      <rect x="78" y="163" width="80" height="6" rx="3" fill="#4fa84a" opacity="0.6" />
      <rect x="78" y="174" width="120" height="4" rx="2" fill="#bee0bc" />
      <rect x="64" y="192" width="188" height="28" rx="6" fill="#f7f7f8" stroke="#e6e6e9" stroke-width="1" />
      <rect x="78" y="199" width="68" height="6" rx="3" fill="#e6e6e9" />
      <rect x="78" y="210" width="110" height="4" rx="2" fill="#e6e6e9" />
      <rect x="64" y="228" width="188" height="28" rx="6" fill="#f7f7f8" stroke="#e6e6e9" stroke-width="1" />
      <rect x="78" y="235" width="72" height="6" rx="3" fill="#e6e6e9" />
      <rect x="78" y="246" width="100" height="4" rx="2" fill="#e6e6e9" />
      {/* Launch arrow */}
      <path d="M295 180 Q330 140 370 130" stroke="#4fa84a" stroke-width="3" fill="none" stroke-linecap="round" marker-end="url(#arrow)" />
      {/* Arrowhead */}
      <defs>
        <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
          <path d="M0 0 L0 6 L8 3 z" fill="#4fa84a" />
        </marker>
      </defs>
      {/* Rocket shape */}
      <ellipse cx="316" cy="170" rx="18" ry="28" fill="#4fa84a" transform="rotate(-45 316 170)" />
      <circle cx="316" cy="170" r="8" fill="#fff" opacity="0.6" />
      {/* Growth chart */}
      <rect x="390" y="88" width="202" height="184" rx="16" fill="#fff" stroke="#e6e6e9" stroke-width="1.5" />
      <rect x="406" y="244" width="170" height="1.5" rx="1" fill="#e6e6e9" />
      <rect x="406" y="104" width="1.5" height="140" rx="1" fill="#e6e6e9" />
      {/* Growth line */}
      <polyline
        points="414,238 450,230 490,210 530,182 558,148"
        fill="none"
        stroke="#4fa84a"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      {/* Area under line */}
      <polygon
        points="414,238 450,230 490,210 530,182 558,148 558,244 414,244"
        fill="#4fa84a"
        opacity="0.08"
      />
      {/* Data dots */}
      <circle cx="450" cy="230" r="4" fill="#4fa84a" />
      <circle cx="490" cy="210" r="4" fill="#4fa84a" />
      <circle cx="530" cy="182" r="4" fill="#4fa84a" />
      <circle cx="558" cy="148" r="5" fill="#4fa84a" />
    </svg>
  )
}

