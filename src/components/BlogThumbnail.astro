---
/**
 * BlogThumbnail — lightweight inline SVG illustrations for blog cards.
 * All variants use brand colors, no external resources, no bitmap images,
 * no readable text inside the graphic (WCAG / LCP friendly).
 *
 * Usage: <BlogThumbnail variant="attribution-flow" />
 */
interface Props {
  variant: string;
  class?: string;
}
const { variant, class: className = '' } = Astro.props;
---

{
  variant === 'attribution-flow' && (
    <svg
      viewBox="0 0 640 360"
      width="100%"
      height="100%"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
      class={className}
    >
      <rect width="640" height="360" fill="#f7f7f8" />
      {/* Step 1: Ad */}
      <rect x="48" y="108" width="116" height="84" rx="12" fill="#fff" stroke="#e6e6e9" stroke-width="1.5" />
      <rect x="48" y="108" width="116" height="8" rx="6" fill="#4fa84a" />
      <rect x="66" y="136" width="80" height="6" rx="3" fill="#e6e6e9" />
      <rect x="66" y="149" width="60" height="6" rx="3" fill="#e6e6e9" />
      <rect x="66" y="162" width="70" height="5" rx="2.5" fill="#bee0bc" />
      {/* Arrow 1 */}
      <line x1="172" y1="150" x2="206" y2="150" stroke="#94cd91" stroke-width="2" stroke-dasharray="5 3" />
      <path d="M203 145 L211 150 L203 155" fill="none" stroke="#4fa84a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      {/* Step 2: Landing page */}
      <rect x="214" y="108" width="116" height="84" rx="12" fill="#fff" stroke="#e6e6e9" stroke-width="1.5" />
      <rect x="214" y="108" width="116" height="20" rx="10" fill="#e6e6e9" />
      <circle cx="231" cy="118" r="3.5" fill="#fff" />
      <circle cx="242" cy="118" r="3.5" fill="#fff" />
      <circle cx="253" cy="118" r="3.5" fill="#fff" />
      <rect x="228" y="142" width="84" height="5" rx="2.5" fill="#e6e6e9" />
      <rect x="228" y="154" width="64" height="5" rx="2.5" fill="#e6e6e9" />
      <rect x="228" y="166" width="54" height="5" rx="2.5" fill="#4fa84a" opacity="0.4" />
      {/* Arrow 2 */}
      <line x1="338" y1="150" x2="370" y2="150" stroke="#94cd91" stroke-width="2" stroke-dasharray="5 3" />
      <path d="M367 145 L375 150 L367 155" fill="none" stroke="#4fa84a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      {/* Step 3: Email envelope */}
      <rect x="378" y="108" width="116" height="84" rx="12" fill="#fff" stroke="#e6e6e9" stroke-width="1.5" />
      <rect x="396" y="124" width="80" height="56" rx="6" fill="#eef6ed" stroke="#bee0bc" stroke-width="1.5" />
      <path d="M396 132 L436 154 L476 132" stroke="#94cd91" stroke-width="1.5" fill="none" />
      {/* Arrow 3 */}
      <line x1="502" y1="150" x2="524" y2="150" stroke="#94cd91" stroke-width="2" stroke-dasharray="5 3" />
      <path d="M521 145 L529 150 L521 155" fill="none" stroke="#4fa84a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      {/* Step 4: Revenue circle */}
      <circle cx="563" cy="150" r="44" fill="#eef6ed" />
      <circle cx="563" cy="150" r="33" fill="#4fa84a" opacity="0.18" />
      <circle cx="563" cy="150" r="24" fill="#4fa84a" />
      {/* Dollar sign: vertical bar + curved path */}
      <line x1="563" y1="137" x2="563" y2="163" stroke="#fff" stroke-width="2.5" stroke-linecap="round" />
      <path d="M556 142 Q556 138 563 138 Q570 138 570 143 Q570 150 563 150 Q570 150 570 157 Q570 162 563 162 Q556 162 556 158" stroke="#fff" stroke-width="1.8" fill="none" stroke-linecap="round" />
      {/* Journey baseline */}
      <line x1="106" y1="228" x2="563" y2="228" stroke="#e6e6e9" stroke-width="1" />
      <circle cx="106" cy="228" r="4" fill="#e6e6e9" />
      <circle cx="272" cy="228" r="4" fill="#e6e6e9" />
      <circle cx="436" cy="228" r="4" fill="#e6e6e9" />
      <circle cx="563" cy="228" r="6" fill="#4fa84a" />
    </svg>
  )
}

