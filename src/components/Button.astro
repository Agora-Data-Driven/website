---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'icon';
  size?: 'md' | 'lg';
  external?: boolean;
  type?: 'button' | 'submit';
  class?: string;
}
const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  type = 'button',
  class: className = '',
} = Astro.props;

const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
const isIcon = variant === 'icon';

// --- Standard buttons: the "interactive hover button" -------------------------
// At rest, an outlined pill with a small brand dot + label. On hover the dot
// scales up to flood the button with brand green, the label slides out to the
// right, and a white "label + arrow" layer slides in from the left. Applied to
// EVERY variant except the "Become a client" icon button. Pure CSS, no JS, no
// React / framer-motion (this is an Astro zero-JS project).
const base =
  'group relative inline-flex items-center justify-center gap-2 overflow-hidden rounded-full border font-semibold will-change-transform disabled:pointer-events-none disabled:opacity-50';
const sizes = {
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3.5 text-base',
};
const interactiveCls = `${base} ${sizes[size]} ihb border-line bg-surface text-ink shadow-card ${className}`;

// --- "icon" variant ----------------------------------------------------------
// A premium pill button: a circular badge sits at the right edge, then on hover
// it glides all the way to the left and rotates 45deg while the label slides
// over to fill the space. Pure CSS transitions, no React, no JS.
//
// How the slide works: the badge is absolutely positioned. At rest it sits at
// `right-1` (4px from the right). On hover it animates to
// `right: calc(100% - <badge+4px>)`, which places it 4px from the LEFT edge,
// a perfectly mirrored slide. The label's inline padding flips at the same time
// (e.g. ps-5/pe-12 -> ps-12/pe-5) so the text shifts right out of the badge's way.
const iconShell =
  'group relative inline-flex w-fit items-center overflow-hidden rounded-full bg-brand-500 font-semibold text-white shadow-[0_4px_14px_-4px_rgba(79,168,74,0.5)] transition-all duration-500 ease-out hover:bg-brand-600 hover:shadow-[0_10px_24px_-6px_rgba(79,168,74,0.6)]';
const iconShellSize = {
  md: 'h-11 text-sm ps-5 pe-12 hover:ps-12 hover:pe-5',
  lg: 'h-14 text-base ps-7 pe-16 hover:ps-16 hover:pe-7',
};
const badgeSize = {
  md: 'h-9 w-9 right-1 group-hover:right-[calc(100%-2.5rem)]',
  lg: 'h-12 w-12 right-1 group-hover:right-[calc(100%-3.25rem)]',
};
const iconCls = `${iconShell} ${iconShellSize[size]} ${className}`;
---

{
  isIcon ? (
    href ? (
      <a href={href} class={iconCls} rel={rel} target={target}>
        <span class="relative z-10 whitespace-nowrap transition-all duration-500 ease-out">
          <slot />
        </span>
        <span
          class={`text-brand-600 absolute top-1/2 grid -translate-y-1/2 place-items-center rounded-full bg-white shadow-sm transition-all duration-500 ease-out group-hover:rotate-45 ${badgeSize[size]}`}
          aria-hidden="true"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17 17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </span>
      </a>
    ) : (
      <button type={type} class={iconCls}>
        <span class="relative z-10 whitespace-nowrap transition-all duration-500 ease-out">
          <slot />
        </span>
        <span
          class={`text-brand-600 absolute top-1/2 grid -translate-y-1/2 place-items-center rounded-full bg-white shadow-sm transition-all duration-500 ease-out group-hover:rotate-45 ${badgeSize[size]}`}
          aria-hidden="true"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17 17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </span>
      </button>
    )
  ) : href ? (
    <a href={href} class={interactiveCls} rel={rel} target={target}>
      <span class="ihb-dot" aria-hidden="true" />
      <span class="ihb-label">
        <slot />
      </span>
      <span class="ihb-reveal" aria-hidden="true">
        <slot />
        <svg
          class="ihb-arrow"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14" />
          <path d="m13 6 6 6-6 6" />
        </svg>
      </span>
    </a>
  ) : (
    <button type={type} class={interactiveCls}>
      <span class="ihb-dot" aria-hidden="true" />
      <span class="ihb-label">
        <slot />
      </span>
      <span class="ihb-reveal" aria-hidden="true">
        <slot />
        <svg
          class="ihb-arrow"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14" />
          <path d="m13 6 6 6-6 6" />
        </svg>
      </span>
    </button>
  )
}

<style>
  /* ---- Interactive hover button -----------------------------------------------
     Every button except the "Become a client" icon button. At rest: an outlined
     pill with a small brand dot + label. On hover (or keyboard focus) the dot
     scales up to flood the pill with brand green, the label slides out to the
     right and fades, and a white "label + arrow" layer slides in from the left.
     Pure CSS, no JS. */
  .ihb {
    isolation: isolate;
    transition:
      border-color 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ihb-dot {
    height: 0.5rem;
    width: 0.5rem;
    flex: none;
    border-radius: 9999px;
    /* Agora brand green (matches the "Become a client" CTA). */
    background: var(--color-brand-500);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Big enough to flood even the widest button from the dot's off-centre origin. */
  .ihb:hover .ihb-dot,
  .ihb:focus-visible .ihb-dot {
    transform: scale(75);
  }
  .ihb-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease;
  }
  .ihb:hover .ihb-label,
  .ihb:focus-visible .ihb-label {
    transform: translateX(5rem);
    opacity: 0;
  }
  .ihb-reveal {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #fff;
    white-space: nowrap;
    transform: translateX(-4rem);
    opacity: 0;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease;
    pointer-events: none;
  }
  .ihb:hover .ihb-reveal,
  .ihb:focus-visible .ihb-reveal {
    transform: translateX(0);
    opacity: 1;
  }
  /* The reveal layer is "label + arrow" only. Suppress any decorative icon that a
     caller put in the slot (e.g. the Facebook glyph) so it is not duplicated here. */
  .ihb-reveal :global(svg:not(.ihb-arrow)) {
    display: none;
  }
  .ihb-arrow {
    height: 1rem;
    width: 1rem;
    flex: none;
  }
  .ihb:hover {
    border-color: var(--color-brand-500);
  }
  .ihb:active {
    transform: scale(0.98);
  }

  /* Honor reduced-motion: skip the giant scale + slides; do an instant, readable
     green fill with the white label instead. */
  @media (prefers-reduced-motion: reduce) {
    .ihb-dot {
      display: none;
    }
    .ihb-label,
    .ihb-reveal {
      transition: none;
    }
    .ihb:hover,
    .ihb:focus-visible {
      background: var(--color-brand-500);
      border-color: var(--color-brand-500);
    }
    .ihb:hover .ihb-label,
    .ihb:focus-visible .ihb-label {
      opacity: 0;
    }
    .ihb:hover .ihb-reveal,
    .ihb:focus-visible .ihb-reveal {
      transform: none;
      opacity: 1;
    }
    .ihb:active {
      transform: none;
    }
  }
</style>
