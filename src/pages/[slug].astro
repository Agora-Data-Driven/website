---
import { getCollection, render } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';

// SSR (no prerender) so that the ag_sso cookie is readable at request time,
// enabling the admin "Change photo" overlay for logged-in admins.
// The flagship "LED Wall" story has its own bespoke page; redirect to it.
const bespokeSlugs = new Set(['building-an-authentic-brand-identity']);
const { slug } = Astro.params;

if (!slug || bespokeSlugs.has(slug)) {
  return Astro.redirect('/building-an-authentic-brand-identity/');
}

const posts = await getCollection('posts', ({ data }) => !data.draft);
const post = posts.find((p) => p.id === slug);
if (!post) return Astro.redirect('/404');

const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  publishDate={post.data.publishDate}
  updatedDate={post.data.updatedDate}
  excerpt={post.data.excerpt}
  heroImage={post.data.heroImage}
  heroAlt={post.data.heroAlt}
  category={post.data.category}
  type={post.data.type}
  slug={post.id}
>
  <Content />
</PostLayout>
