---
import CaseStudyLayout from '@layouts/CaseStudyLayout.astro';
import { caseStudies } from '@data/portfolio';

export const prerender = true;
const study = caseStudies.find((c) => c.slug === 'case-study-community-events')!;
---

<CaseStudyLayout
  eyebrow={study.tag}
  title={study.title}
  summary={study.summary}
  heroImage={study.image ?? study.heroImage}
  heroAlt={`${study.cardTitle} campaign`}
  metrics={study.metrics}
>
  {
    study.sections.map((s) => (
      <Fragment>
        <h2>{s.heading}</h2>
        {s.body.map((p) => (
          <p>{p}</p>
        ))}
      </Fragment>
    ))
  }
</CaseStudyLayout>
