---
/**
 * Bespoke landing page for the flagship "LED Wall" story, light / white
 * minimalist treatment (bold black type, generous white space, green reserved
 * for CTAs and small accents, per the brand kit). No dark surfaces.
 *
 * The Markdown file stays the single source of truth for the blog listing card
 * + SEO frontmatter; this page reads that frontmatter via getEntry, and
 * [slug].astro excludes the slug so there's no duplicate-route collision. All
 * copy is drawn from the real article, no invented metrics ("6 industries" is
 * the count of verticals named in the Results section).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Button from '@components/Button.astro';
import { cta } from '@data/cta';
import { site } from '@data/site';
import { getSilo } from '@data/categories';
import { getEntry } from 'astro:content';

export const prerender = true;

const post = await getEntry('posts', 'building-an-authentic-brand-identity');
if (!post) throw new Error('Missing post: building-an-authentic-brand-identity');

const { title, excerpt, publishDate, updatedDate, category } = post.data;
const silo = category ? getSilo(category) : undefined;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = new URL(Astro.url.pathname, site.url).href;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  ...(silo ? [{ label: silo.name, href: `/blog/category/${silo.slug}/` }] : []),
  { label: title },
];

// --- Page content model (all real, from the article) ----------------------

const stats = [
  { value: 'Thousands', label: 'Reached daily', sub: 'High-traffic placement' },
  { value: '6', label: 'Industries booked', sub: 'In the first month' },
  { value: 'Month 1', label: 'First bookings live', sub: 'Real paying advertisers' },
  { value: '1 screen', label: 'A repeatable playbook', sub: 'Proven, then offered out' },
];

const industries = ['Food & Beverage', 'Music', 'Pharmacy', 'Beauty', 'Printing', 'Influencers'];

const strategy = [
  {
    tag: 'Creative',
    title: 'Content-driven presentation',
    body: 'High-quality visuals showed the wall displaying live ads and capturing foot traffic across different times of day, proof the screen works, not just a render.',
  },
  {
    tag: 'Demand',
    title: 'Targeted social media ads',
    body: 'Facebook campaigns reached business owners in food, retail, health, beauty, music, and events with one clear message: “Want your ad here? Message us to book your slot.”',
  },
];

const pillars = [
  {
    title: 'Ad consultation',
    body: 'We help advertisers shape a message that actually lands on a moving, glanceable screen.',
  },
  {
    title: 'Strategic scheduling',
    body: 'Slots are placed during peak foot-traffic windows, so spend buys attention, not dead air.',
  },
  {
    title: 'Cross-promotion',
    body: 'Each booking is amplified across our social channels, stretching reach beyond the street.',
  },
  {
    title: 'Performance tracking',
    body: 'We report back with actionable insights, so advertisers see what worked and what to run next.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  datePublished: publishDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  author: { '@type': 'Organization', name: site.name, url: site.url },
  publisher: { '@type': 'Organization', name: site.name, url: site.url },
  mainEntityOfPage: canonical,
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: c.href ? new URL(c.href, site.url).href : canonical,
  })),
};
---

<BaseLayout title={title} description={excerpt} type="article">
  <article>
    <!-- ============================================================ HERO -->
    <header class="border-line relative overflow-hidden border-b">
      <!-- Roaming green aurora, clipped to this band and painted behind the
           content (the Container below is lifted to z-10). -->
      <div class="aurora" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
      </div>
      <div
        class="bg-grid pointer-events-none absolute inset-0 [mask-image:radial-gradient(ellipse_at_top_left,black,transparent_72%)] opacity-60"
        aria-hidden="true"
      >
      </div>
      <div
        class="bg-brand-300/30 pointer-events-none absolute -top-40 -right-32 h-[34rem] w-[34rem] rounded-full blur-[130px]"
        aria-hidden="true"
      >
      </div>

      <Container size="wide" class="relative z-10 pt-8 pb-16 lg:pt-10 lg:pb-24">
        <!-- Breadcrumb (light) -->
        <nav aria-label="Breadcrumb" class="reveal">
          <ol class="text-muted flex flex-wrap items-center gap-1.5 text-sm">
            {
              crumbs.map((c, i) => (
                <li class="flex items-center gap-1.5">
                  {c.href && i < crumbs.length - 1 ? (
                    <a href={c.href} class="hover:text-brand-700">
                      {c.label}
                    </a>
                  ) : (
                    <span class="text-body font-medium" aria-current="page">
                      {c.label}
                    </span>
                  )}
                  {i < crumbs.length - 1 && <span aria-hidden="true">/</span>}
                </li>
              ))
            }
          </ol>
        </nav>

        <div class="mt-10 grid items-center gap-14 lg:mt-12 lg:grid-cols-[1.05fr_0.95fr]">
          <!-- Copy -->
          <div>
            <p
              class="reveal border-brand-200 bg-tint/70 text-brand-700 inline-flex items-center gap-2 rounded-full border py-1.5 pr-4 pl-2.5 text-xs font-semibold tracking-wide uppercase backdrop-blur"
            >
              <span
                class="bg-brand-500 grid h-4 w-4 place-items-center rounded-full"
                aria-hidden="true"
              >
                <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
              </span>
              {silo?.name ?? 'Strategy & Growth'} · Field Story
            </p>

            <h1
              class="reveal text-ink mt-6 text-4xl leading-[1.03] font-bold sm:text-5xl lg:text-[4.25rem]"
              style="--reveal-delay: 80ms"
            >
              From Display to
              <span class="text-gradient block">Demand.</span>
            </h1>

            <p class="reveal text-muted mt-6 max-w-xl text-lg" style="--reveal-delay: 160ms">
              {excerpt}
            </p>

            <div class="reveal mt-8 flex flex-wrap gap-4" style="--reveal-delay: 240ms">
              <Button href={cta.becomeClient.href} external size="lg">Book a slot</Button>
              <a
                href="#story"
                class="group border-line bg-surface text-ink shadow-card hover:border-brand-400 hover:text-brand-600 inline-flex items-center justify-center gap-2 rounded-full border px-7 py-3.5 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5"
              >
                Read the story
                <span
                  class="transition-transform duration-200 group-hover:translate-y-0.5"
                  aria-hidden="true">↓</span
                >
              </a>
            </div>

            <div
              class="reveal text-muted mt-9 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm"
              style="--reveal-delay: 320ms"
            >
              <span class="flex items-center gap-2">
                <span class="bg-brand-500 h-1.5 w-1.5 rounded-full" aria-hidden="true"></span>
                <time datetime={publishDate.toISOString()}>{fmt(publishDate)}</time>
              </span>
              <span class="bg-line hidden h-4 w-px sm:block" aria-hidden="true"></span>
              <span>3 min read</span>
              <span class="bg-line hidden h-4 w-px sm:block" aria-hidden="true"></span>
              <span>Owned-media case study</span>
            </div>
          </div>

          <!-- Simulated LED wall (light, pure CSS, decorative) -->
          <div class="reveal relative" style="--reveal-delay: 200ms" aria-hidden="true">
            <div
              class="bg-brand-300/25 pointer-events-none absolute -inset-8 -z-10 rounded-[3rem] blur-3xl"
            >
            </div>

            <div class="relative mx-auto max-w-[340px]">
              <div class="led-frame">
                <div class="led-screen">
                  <video
                    class="led-video"
                    src="/LED.mp4"
                    autoplay
                    loop
                    muted
                    playsinline
                    preload="auto"
                  >
                  </video>
                  <div class="led-sweep"></div>
                </div>
                <div class="led-stand"></div>
              </div>

              <!-- Floating proof chips -->
              <div
                class="border-line bg-surface shadow-pop absolute -bottom-5 -left-3 hidden rounded-xl border px-4 py-3 sm:block"
              >
                <div class="font-display text-brand-600 text-sm font-bold">6 industries</div>
                <div class="text-muted text-[0.7rem]">Booked in month one</div>
              </div>
              <div
                class="border-line bg-surface shadow-pop absolute -top-5 -right-3 hidden rounded-xl border px-4 py-3 md:block"
              >
                <div class="font-display text-accent-600 text-sm font-bold">Live ↗</div>
                <div class="text-muted text-[0.7rem]">Real paying advertisers</div>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </header>

    <!-- ====================================================== STAT BAND -->
    <section class="border-line bg-surface border-b">
      <Container size="wide" class="py-12 lg:py-14">
        <dl class="grid grid-cols-2 gap-x-6 gap-y-9 lg:grid-cols-4 lg:gap-x-8">
          {
            stats.map((s, i) => (
              <div class="reveal" style={`--reveal-delay: ${i * 90}ms`}>
                <dt class="sr-only">{s.label}</dt>
                <dd>
                  <span class="font-display text-gradient text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
                    {s.value}
                  </span>
                  <p class="font-display text-ink mt-3 text-sm font-semibold">{s.label}</p>
                  <p class="text-muted mt-1 text-xs">{s.sub}</p>
                </dd>
              </div>
            ))
          }
        </dl>
      </Container>
    </section>

    <!-- ========================================================= INTRO -->
    <section id="story" class="relative scroll-mt-24 overflow-hidden py-16 lg:py-24">
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
      </div>
      <Container size="narrow" class="relative z-10">
        <p class="eyebrow reveal">The brief</p>
        <p
          class="reveal text-ink mt-5 text-2xl leading-snug font-semibold sm:text-[1.75rem] sm:leading-snug"
          style="--reveal-delay: 80ms"
        >
          When we invested in an LED wall, the goal went beyond displaying ads, it was to produce
          <span class="text-gradient">measurable outcomes</span>. Positioned in a high-traffic spot,
          the wall reached thousands of people daily.
        </p>
        <p class="reveal text-muted mt-5 text-lg" style="--reveal-delay: 140ms">
          The critical question became: how do we turn visibility into value, not just for us, but
          for our future clients?
        </p>
      </Container>
    </section>

    <!-- ====================================== VISION: more than a billboard -->
    <section class="border-line bg-surface relative overflow-hidden border-y py-16 lg:py-24">
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
      </div>
      <Container size="wide" class="relative z-10">
        <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
          <div class="reveal">
            <p class="eyebrow">The vision</p>
            <h2 class="text-ink mt-4 text-3xl font-bold sm:text-[2.6rem] sm:leading-[1.05]">
              More than a billboard
            </h2>
            <p class="text-muted mt-5 text-lg">
              It's easy to think of an LED wall as just a bigger billboard. We saw it differently.
              Owning the screen meant we could test, measure, and prove what actually drives
              advertising results, then offer that same playbook to local businesses.
            </p>
          </div>

          <!-- Billboard vs. owned channel contrast -->
          <div class="reveal grid gap-4 sm:grid-cols-2" style="--reveal-delay: 120ms">
            <div class="border-line bg-canvas rounded-2xl border p-6">
              <p class="text-muted text-xs font-semibold tracking-wide uppercase">
                A rented billboard
              </p>
              <ul class="text-muted mt-4 space-y-3 text-sm">
                <li class="flex gap-2">
                  <span aria-hidden="true">-</span> Pay, post, and hope
                </li>
                <li class="flex gap-2">
                  <span aria-hidden="true">-</span> No feedback loop
                </li>
                <li class="flex gap-2">
                  <span aria-hidden="true">-</span> Static, set-and-forget
                </li>
              </ul>
            </div>
            <div class="border-brand-200 bg-tint rounded-2xl border p-6">
              <p class="text-brand-700 text-xs font-semibold tracking-wide uppercase">
                An owned channel
              </p>
              <ul class="text-body mt-4 space-y-3 text-sm font-medium">
                <li class="flex gap-2">
                  <span class="text-brand-500" aria-hidden="true">✓</span> Test &amp; measure
                </li>
                <li class="flex gap-2">
                  <span class="text-brand-500" aria-hidden="true">✓</span> Prove what works
                </li>
                <li class="flex gap-2">
                  <span class="text-brand-500" aria-hidden="true">✓</span> Resell the playbook
                </li>
              </ul>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- =============================== STRATEGY: treat ourselves like a client -->
    <section class="relative overflow-hidden py-16 lg:py-24">
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
      </div>
      <Container size="wide" class="relative z-10">
        <div class="reveal max-w-2xl">
          <p class="eyebrow">The strategy</p>
          <h2 class="text-ink mt-4 text-3xl font-bold sm:text-[2.6rem] sm:leading-[1.05]">
            We treated ourselves like a client
          </h2>
          <p class="text-muted mt-4 text-lg">
            Same rigor, same data-informed approach we'd bring to any account, pointed at our own
            screen.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {
            strategy.map((s, i) => (
              <div
                class="reveal glow-card border-line bg-surface shadow-card card-hover group flex flex-col rounded-2xl border p-8"
                style={`--reveal-delay: ${i * 110}ms`}
              >
                <div class="flex items-center gap-3">
                  <span class="bg-tint text-brand-700 font-display grid h-10 w-10 place-items-center rounded-xl text-sm font-bold">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="text-brand-600 text-xs font-semibold tracking-wide uppercase">
                    {s.tag}
                  </span>
                </div>
                <h3 class="text-ink mt-5 text-xl font-bold">{s.title}</h3>
                <p class="text-muted mt-3 text-[0.975rem] leading-relaxed">{s.body}</p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- ================================================ RESULTS: industries -->
    <section class="border-line bg-surface relative overflow-hidden border-y py-16 lg:py-24">
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
      </div>
      <Container size="wide" class="relative z-10">
        <div class="reveal max-w-2xl">
          <p class="eyebrow">The results</p>
          <h2 class="text-ink mt-4 text-3xl font-bold sm:text-[2.6rem] sm:leading-[1.05]">
            Real bookings. <span class="text-gradient">Real clients.</span>
          </h2>
          <p class="text-muted mt-4 text-lg">
            The first month yielded multiple advertising bookings across diverse industries,
            visibility converted into demand.
          </p>
        </div>

        <ul class="reveal mt-10 flex flex-wrap gap-3" style="--reveal-delay: 120ms">
          {
            industries.map((name) => (
              <li class="border-line bg-canvas text-body inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium">
                <span class="bg-brand-500 h-1.5 w-1.5 rounded-full" aria-hidden="true" />
                {name}
              </li>
            ))
          }
        </ul>
      </Container>
    </section>

    <!-- ================================ WHY IT WORKED: support pillars -->
    <section class="relative overflow-hidden py-16 lg:py-24">
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
      </div>
      <Container size="wide" class="relative z-10">
        <div class="reveal max-w-2xl">
          <p class="eyebrow">Why it worked</p>
          <h2 class="text-ink mt-4 text-3xl font-bold sm:text-[2.6rem] sm:leading-[1.05]">
            Strategy beyond the screen
          </h2>
          <p class="text-muted mt-4 text-lg">
            Success came from comprehensive marketing support around every booking, not just the
            hardware.
          </p>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {
            pillars.map((p, i) => (
              <div
                class="reveal glow-card border-line bg-surface shadow-card card-hover rounded-2xl border p-6"
                style={`--reveal-delay: ${i * 90}ms`}
              >
                <span
                  class="bg-tint text-brand-600 font-display grid h-9 w-9 place-items-center rounded-lg text-sm font-bold"
                  aria-hidden="true"
                >
                  {i + 1}
                </span>
                <h3 class="text-ink mt-4 text-base font-bold">{p.title}</h3>
                <p class="text-muted mt-2 text-sm leading-relaxed">{p.body}</p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- ===================================================== TAKEAWAY -->
    <section class="pb-4">
      <Container size="narrow">
        <figure
          class="reveal border-line bg-surface relative overflow-hidden rounded-3xl border px-7 py-12 text-center sm:px-12 sm:py-16"
        >
          <div class="bg-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true">
          </div>
          <div class="relative">
            <span class="text-brand-500 font-display text-5xl leading-none" aria-hidden="true"
              >“</span
            >
            <blockquote
              class="text-ink mx-auto mt-2 max-w-2xl text-2xl font-bold sm:text-3xl sm:leading-tight"
            >
              Visibility backed by a marketing team beats a standard billboard rental
              <span class="text-gradient">every time.</span>
            </blockquote>
            <figcaption class="text-muted mt-6 text-sm font-medium tracking-wide uppercase">
              The takeaway
            </figcaption>
          </div>
        </figure>
      </Container>
    </section>

    <!-- ========================================================== CTA -->
    <section class="py-16 lg:py-24">
      <Container>
        <div
          class="reveal border-brand-200 from-brand-50 via-tint to-surface shadow-glow relative overflow-hidden rounded-3xl border bg-linear-to-br px-6 py-14 text-center sm:px-12 lg:py-20"
        >
          <div class="bg-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true">
          </div>

          <div class="relative">
            <p
              class="border-brand-200 bg-surface/80 text-brand-700 mx-auto inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-semibold tracking-wide uppercase backdrop-blur"
            >
              <span class="bg-brand-500 h-1.5 w-1.5 rounded-full" aria-hidden="true"></span>
              Want your ad here?
            </p>
            <h2
              class="text-ink mx-auto mt-6 max-w-2xl text-3xl font-bold sm:text-[2.6rem] sm:leading-[1.05]"
            >
              Let's turn a high-traffic screen into <span class="text-gradient">your demand</span>
            </h2>
            <p class="text-muted mx-auto mt-4 max-w-xl">
              Whether it's our LED wall or your next campaign, we bring the same data-informed
              playbook. Message us to book a slot.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-4">
              <Button href={cta.becomeClient.href} external variant="icon" size="lg">
                Become a client
              </Button>
              <Button href={cta.facebook.href} external variant="secondary" size="lg">
                <svg
                  class="h-5 w-5 shrink-0"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8v8.44C19.61 23.08 24 18.09 24 12.07Z"
                  ></path>
                </svg>
                Follow on Facebook
              </Button>
            </div>
            <p class="text-muted mt-6 text-xs font-medium tracking-wide uppercase">
              Top Rated on Upwork · Replies fast · No obligation
            </p>
          </div>
        </div>

        <div class="border-line mt-12 border-t pt-6 text-center">
          <a href="/blog/" class="text-brand-600 hover:text-brand-700 text-sm font-semibold">
            &larr; Back to all articles
          </a>
        </div>
      </Container>
    </section>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />
</BaseLayout>

<style>
  /* ---- Simulated LED wall, light, minimal (decorative, pure CSS) ------- */
  .led-frame {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin-inline: auto;
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    padding: 0.75rem;
    box-shadow: var(--shadow-pop);
  }
  .led-screen {
    position: relative;
    aspect-ratio: 9 / 16; /* matches LED.mp4 (1080x1920) exactly: no crop, no bars */
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
    border: 1px solid var(--color-line);
    line-height: 0;
  }
  /* Looping LED-wall video, fills the panel at its native 9:16 ratio (never cropped) */
  .led-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Soft sheen sweeping across, like a refresh pass */
  .led-sweep {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 38%,
      rgba(79, 168, 74, 0.1) 50%,
      transparent 62%
    );
    transform: translateX(-30%);
    animation: led-sweep 6.5s ease-in-out infinite;
  }
  @keyframes led-sweep {
    0%,
    100% {
      transform: translateX(-35%);
    }
    50% {
      transform: translateX(35%);
    }
  }
  .led-stand {
    margin: 0.75rem auto 0;
    width: 14%;
    height: 1.4rem;
    background: linear-gradient(to bottom, var(--color-line), transparent);
    border-radius: 0 0 4px 4px;
  }
  .led-stand::after {
    content: '';
    display: block;
    width: 320%;
    height: 6px;
    margin: 0 auto;
    transform: translateX(-22%);
    border-radius: 9999px;
    background: var(--color-line);
  }

  /* ---- Mouse-follow green spotlight on the strategy / pillar cards -------
     Decorative only. --mx/--my are set by the script below on pointermove;
     without JS (touch / reduced motion) the glow simply sits centred at the
     top and still fades in on hover. Content is lifted above the glow. */
  .glow-card {
    position: relative;
    isolation: isolate;
    --mx: 50%;
    --my: 0%;
  }
  .glow-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      240px circle at var(--mx) var(--my),
      rgba(79, 168, 74, 0.14),
      transparent 72%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }
  .glow-card:hover::before {
    opacity: 1;
  }
  .glow-card > :global(*) {
    position: relative;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .led-sweep {
      animation: none;
    }
    .glow-card::before {
      transition: none;
    }
  }
</style>

<script>
  // ---- Page motion: bidirectional scroll reveal + card spotlight -----------
  // Purely additive. No content, copy, or layout is touched.
  const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isTouch = window.matchMedia('(pointer: coarse)').matches;

  // BaseLayout reveals each .reveal once, then stops observing. Keep observing
  // and *toggle*, so blocks animate scrolling UP as well as down. Skipped for
  // reduced-motion (BaseLayout has already shown everything).
  if (!prefersReduce && 'IntersectionObserver' in window) {
    const revealIO = new IntersectionObserver(
      (entries) => {
        for (const e of entries) e.target.classList.toggle('is-visible', e.isIntersecting);
      },
      { threshold: 0.12, rootMargin: '0px 0px -6% 0px' },
    );
    document.querySelectorAll('article .reveal').forEach((el) => revealIO.observe(el));
  }

  // Green glow follows the cursor across the cards. Desktop + motion-ok only.
  if (!prefersReduce && !isTouch) {
    document.querySelectorAll<HTMLElement>('.glow-card').forEach((card) => {
      card.addEventListener('pointermove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });
    });
  }
</script>
