<script>
  // Green mouse-follow spotlight on the test cards — the "moving" accent.
  // Desktop + motion-ok only; touch and reduced-motion fall back to the
  // centered hover glow defined in the scoped <style> above.
  const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isTouch = window.matchMedia('(pointer: coarse)').matches;
  if (!prefersReduce && !isTouch) {
    document.querySelectorAll<HTMLElement>('.test-card').forEach((card) => {
      card.addEventListener('pointermove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });
    });
  }

  // ── Bidirectional scroll reveal ───────────────────────────────────────────
  // BaseLayout reveals each .reveal once then stops observing. Here we keep
  // observing and *toggle*, so sections animate scrolling UP as well as down.
  // Reduced-motion is skipped (BaseLayout already shows everything).
  if (!prefersReduce && 'IntersectionObserver' in window) {
    const revealIO = new IntersectionObserver(
      (entries) => {
        for (const e of entries) e.target.classList.toggle('is-visible', e.isIntersecting);
      },
      { threshold: 0.12, rootMargin: '0px 0px -6% 0px' },
    );
    document.querySelectorAll('#hub .reveal').forEach((el) => revealIO.observe(el));

    // The step connector sweeps its green fill across as the row enters view.
    const stepsGrid = document.querySelector('.steps-grid');
    if (stepsGrid) {
      const stepsIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) e.target.classList.toggle('steps-in', e.isIntersecting);
        },
        { threshold: 0.35 },
      );
      stepsIO.observe(stepsGrid);
    }
  }

  // ── Field tabs → drive the hidden <select> the filter logic already reads ──
  const topicSelect = document.getElementById('filter-topic') as HTMLSelectElement | null;
  const pills = Array.from(document.querySelectorAll<HTMLElement>('.filter-pill'));
  if (topicSelect && pills.length) {
    const syncPills = () => {
      pills.forEach((p) => {
        const on = (p.dataset.value ?? '') === topicSelect.value;
        p.classList.toggle('is-active', on);
        p.setAttribute('aria-selected', String(on));
      });
    };
    pills.forEach((p) =>
      p.addEventListener('click', () => {
        topicSelect.value = p.dataset.value ?? '';
        topicSelect.dispatchEvent(new Event('change', { bubbles: true }));
        syncPills();
      }),
    );
    topicSelect.addEventListener('change', syncPills);
    // "Clear filters" resets the select directly, so re-sync on the next tick.
    document
      .getElementById('clear-filters-btn')
      ?.addEventListener('click', () => setTimeout(syncPills, 0));
    syncPills();
  }

  // ── Click ripple on every button ──────────────────────────────────────────
  // Delegated from the document so the quiz's runtime-rendered buttons get it
  // too. Purely decorative: it never intercepts or cancels the click.
  if (!prefersReduce) {
    document.addEventListener('pointerdown', (e) => {
      const target = e.target as HTMLElement | null;
      const btn = target?.closest<HTMLElement>('#hub button, #quiz-overlay button, .mastery-cta');
      if (!btn || btn.hasAttribute('disabled')) return;
      const rect = btn.getBoundingClientRect();
      if (!rect.width || !rect.height) return;
      const size = Math.max(rect.width, rect.height);
      const ripple = document.createElement('span');
      ripple.className = 'ripple';
      ripple.style.width = `${size}px`;
      ripple.style.height = `${size}px`;
      ripple.style.left = `${e.clientX - rect.left - size / 2}px`;
      ripple.style.top = `${e.clientY - rect.top - size / 2}px`;
      btn.appendChild(ripple);
      ripple.addEventListener('animationend', () => ripple.remove(), { once: true });
    });
  }

  // ── Magnetic buttons ──────────────────────────────────────────────────────
  // Buttons drift a few pixels toward the cursor and spring back on leave.
  // Writes CSS vars so it composes with the press scale rather than
  // overwriting the transform. Desktop + motion-ok only.
  if (!prefersReduce && !isTouch) {
    const MAX = 5;
    const attachMagnet = (btn: HTMLElement) => {
      if (btn.dataset.magnetic) return;
      btn.dataset.magnetic = '1';
      btn.addEventListener('pointermove', (e) => {
        const r = btn.getBoundingClientRect();
        const dx = (e.clientX - (r.left + r.width / 2)) * 0.22;
        const dy = (e.clientY - (r.top + r.height / 2)) * 0.32;
        btn.style.setProperty('--bx', `${Math.max(-MAX, Math.min(MAX, dx))}px`);
        btn.style.setProperty('--by', `${Math.max(-MAX, Math.min(MAX, dy))}px`);
      });
      btn.addEventListener('pointerleave', () => {
        btn.style.setProperty('--bx', '0px');
        btn.style.setProperty('--by', '0px');
      });
    };
    document.querySelectorAll<HTMLElement>('#hub button, .mastery-cta').forEach(attachMagnet);
    // The quiz renders its buttons at runtime — attach on first hover. Answer
    // options are excluded: they are large blocks, and drifting would feel off.
    document.addEventListener('pointerover', (e) => {
      const btn = (e.target as HTMLElement | null)?.closest<HTMLElement>(
        '#quiz-overlay button:not(.option-btn)',
      );
      if (btn) attachMagnet(btn);
    });
  }
</script>
