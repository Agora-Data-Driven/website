---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import { quizTopics } from '@data/quizData';
import type { QuizTopic } from '@data/quizData';
import { cta } from '@data/cta';
import { skillMasteryPath } from '@data/nav';

const checklistItems = [
  'Data science & analytics',
  'AI integration',
  'Organic content & SEO',
  'Paid media buying',
  'Website conversion',
  'Retention, CRM & email',
];

const steps = [
  {
    number: '01',
    title: 'Pick a skill',
    text: 'Choose the field you want to test: your own, or a candidate or VA’s.',
  },
  {
    number: '02',
    title: 'Choose your depth',
    text: 'Answer 5, 10, or 20 questions.',
  },
  {
    number: '03',
    title: 'Right or wrong',
    text: 'Real questions with real answers, and instant feedback after each one.',
  },
  {
    number: '04',
    title: 'See your true level',
    text: 'An honest score, a full review of what you missed, and where to go deeper.',
  },
];
---

<BaseLayout
  title="Free Skill Tests | Test Your Data, Marketing & AI Skills | Agora Data Driven"
  description="Take a free skill test with real right-and-wrong questions. Benchmark your own or your team's proficiency in data science, AI, SEO, paid media, conversion, and CRM. Then master it."
>
  <!-- ── HUB VIEW ──────────────────────────────────────────────────────────── -->
  <div id="hub">
    <!-- ── HERO ────────────────────────────────────────────────────────────── -->
    <section class="border-line bg-surface relative overflow-hidden border-b">
      <!-- Moving aurora: soft green/violet light drifting behind the hero -->
      <div class="aurora" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
      </div>
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(900px 600px at 110% -10%, rgba(79,168,74,0.07) 0%, transparent 60%), linear-gradient(150deg, rgba(238,246,237,0.5) 0%, transparent 45%);"
        aria-hidden="true"
      >
      </div>
      <div
        class="border-brand-300/30 spin-slow pointer-events-none absolute -top-20 -right-20 h-72 w-72 rounded-full border-2"
        style="border-style:dashed"
        aria-hidden="true"
      >
      </div>
      <div
        class="border-brand-200/25 spin-slower pointer-events-none absolute -top-6 -right-6 h-44 w-44 rounded-full border"
        style="border-style:dashed"
        aria-hidden="true"
      >
      </div>

      <Container>
        <div class="relative grid gap-12 py-20 lg:grid-cols-2 lg:gap-16 lg:py-28">
          <!-- Left -->
          <div class="flex flex-col justify-center">
            <p
              class="eyebrow text-brand-600 reveal mb-3 inline-flex items-center gap-2 text-xs font-bold tracking-[0.18em] uppercase"
            >
              <span class="bg-brand-500/10 border-brand-200 rounded-full border px-2.5 py-0.5"
                >Free skill tests · Guest mode</span
              >
            </p>

            <h1
              class="font-display text-ink reveal mb-5 text-4xl leading-tight font-bold tracking-tight lg:text-5xl"
              style="--reveal-delay:80ms"
            >
              How sharp are<br />
              <span class="text-gradient-animated">your skills, really?</span>
            </h1>

            <p class="text-body reveal mb-7 text-lg leading-relaxed" style="--reveal-delay:160ms">
              Real questions with real right and wrong answers. Test your own proficiency, or have
              your team or VAs take it, then jump into Mastery Mode to close the gaps.
            </p>

            <ul
              class="hero-values reveal mb-9 grid grid-cols-2 gap-x-6 gap-y-3"
              style="--reveal-delay:240ms"
            >
              {
                checklistItems.map((item) => (
                  <li class="text-muted flex items-center gap-2 text-sm">
                    <svg
                      class="text-brand-500 h-3.5 w-3.5 shrink-0"
                      viewBox="0 0 14 14"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M2 7l3.5 3.5L12 3" />
                    </svg>
                    {item}
                  </li>
                ))
              }
            </ul>

            <div class="reveal flex flex-wrap gap-3" style="--reveal-delay:320ms">
              <button
                id="hero-choose-btn"
                class="btn-sheen bg-brand-500 shadow-glow-sm hover:bg-brand-600 focus-visible:outline-brand-500 inline-flex items-center rounded-lg px-6 py-3 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2"
              >
                Choose a Test
              </button>
              <a
                href={skillMasteryPath}
                class="mastery-cta border-line text-body hover:border-brand-400 hover:text-brand-700 inline-flex items-center gap-1.5 rounded-lg border px-5 py-3 text-sm font-semibold transition-colors"
                data-auth-label="Go to Mastery Mode →"
              >
                Sign in to Mastery Mode →
              </a>
            </div>
          </div>

          <!-- Right: Preview card -->
          <div class="flex items-center justify-center lg:justify-end">
            <div
              class="border-line bg-surface shadow-pop float-soft w-full max-w-sm rounded-2xl border p-6"
              id="hero-card"
            >
              <p class="text-muted mb-4 text-xs font-semibold tracking-widest uppercase">
                Start a skill test
              </p>

              <!-- Topic tiles -->
              <div
                id="hero-tiles"
                class="mb-5 grid grid-cols-2 gap-2"
                role="listbox"
                aria-label="Select a test topic"
              >
                {
                  quizTopics.map((topic: QuizTopic, i: number) => (
                    <button
                      type="button"
                      role="option"
                      aria-selected={i === 0 ? 'true' : 'false'}
                      data-topic-id={topic.id}
                      class:list={[
                        'hero-tile rounded-lg border px-3 py-2 text-left text-xs font-medium transition-all',
                        i === 0
                          ? 'border-brand-400 bg-brand-50 text-brand-700'
                          : 'border-line text-body hover:border-brand-300 hover:bg-brand-50',
                      ]}
                    >
                      {topic.shortTitle}
                    </button>
                  ))
                }
              </div>

              <!-- Dynamic info -->
              <div id="hero-info" class="mb-5">
                <p id="hero-topic-title" class="text-ink mb-1 text-sm font-semibold">
                  {quizTopics[0].title}
                </p>
                <p id="hero-topic-desc" class="text-muted text-xs leading-relaxed">
                  {quizTopics[0].description}
                </p>
              </div>

              <!-- Question count -->
              <div class="mb-5">
                <p class="text-muted mb-2 text-xs font-medium">Number of questions</p>
                <div
                  class="flex gap-2"
                  id="hero-count-btns"
                  role="group"
                  aria-label="Number of questions"
                >
                  {
                    [5, 10, 20].map((n) => (
                      <button
                        type="button"
                        data-count={n}
                        class:list={[
                          'hero-count-btn flex-1 rounded-lg border py-2 text-sm font-medium transition-all',
                          n === 10
                            ? 'border-brand-400 bg-brand-50 text-brand-700'
                            : 'border-line text-body hover:border-brand-300 hover:bg-brand-50',
                        ]}
                        aria-pressed={n === 10 ? 'true' : 'false'}
                      >
                        {n}
                      </button>
                    ))
                  }
                </div>
              </div>

              <button
                id="hero-start-btn"
                type="button"
                class="btn-sheen bg-brand-500 shadow-glow-sm hover:bg-brand-600 focus-visible:outline-brand-500 mb-3 w-full rounded-lg py-3 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2"
              >
                Start Test
              </button>
              <p id="hero-time-estimate" class="text-muted text-center text-xs">
                Free · No sign-up · Nothing saved
              </p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── QUIZ FROM MY NOTES ────────────────────────────────────────────── -->
    <!-- Bring-your-own-material: upload docs / paste text and the Skill Mastery
         engine writes a quiz on exactly that. Generation is gated behind the
         shared Mastery sign-in (enforced by /api/notes-quiz). -->
    <section class="border-line bg-surface relative overflow-hidden border-b py-14 lg:py-16">
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(820px 360px at 90% -20%, rgba(79,168,74,0.10), transparent 60%)"
        aria-hidden="true"
      >
      </div>
      <Container class="relative z-10">
        <div
          class="border-brand-200 from-brand-50 reveal relative overflow-hidden rounded-2xl border bg-gradient-to-br to-transparent p-7 lg:p-9"
        >
          <div class="grid items-center gap-6 lg:grid-cols-[1fr_auto]">
            <div class="max-w-2xl">
              <p
                class="eyebrow text-brand-600 mb-3 inline-flex items-center gap-2 text-xs font-bold tracking-[0.16em] uppercase"
              >
                <span class="bg-brand-500/10 border-brand-200 rounded-full border px-2.5 py-0.5"
                  >New · Bring your own material</span
                >
              </p>
              <h2 class="font-display text-ink mb-3 text-2xl font-bold tracking-tight lg:text-3xl">
                Quiz yourself on your own notes
              </h2>
              <p class="text-muted mb-5 text-base leading-relaxed">
                Upload a lecture PDF, a photo of your notes, or paste any text, and the Skill
                Mastery engine writes a real quiz on exactly that: your material, real right and
                wrong answers, an explanation after every question. Pick how many questions and how
                hard.
              </p>
              <div class="flex flex-wrap items-center gap-3">
                <button
                  id="notes-quiz-btn"
                  type="button"
                  class="btn-sheen bg-brand-500 shadow-glow-sm hover:bg-brand-600 focus-visible:outline-brand-500 inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                    <path d="M14 3v5h5"></path>
                    <path d="M12 18v-6"></path>
                    <path d="M9.5 14.5 12 12l2.5 2.5"></path>
                  </svg>
                  Create a quiz from my notes
                </button>
                <span class="text-muted text-xs">PDF, images, or text · Mastery sign-in</span>
              </div>
            </div>
            <div
              class="text-brand-600/80 hidden shrink-0 lg:block"
              aria-hidden="true"
            >
              <svg
                class="h-28 w-28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.1"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                <path d="M14 3v5h5"></path>
                <path d="M9 13h6"></path>
                <path d="M9 17h4"></path>
              </svg>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── GUEST vs MASTERY ──────────────────────────────────────────────── -->
    <section class="border-line bg-canvas relative overflow-hidden border-b py-16 lg:py-20">
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
      </div>
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(720px 300px at 10% -10%, rgba(79,168,74,0.08), transparent 60%)"
        aria-hidden="true"
      >
      </div>
      <Container class="relative z-10">
        <div class="reveal relative mb-10 max-w-2xl">
          <p class="eyebrow mb-3">Guest vs Mastery</p>
          <h2 class="font-display text-ink mb-3 text-3xl font-bold tracking-tight lg:text-4xl">
            Two ways in
          </h2>
          <p class="text-muted text-lg">
            Start free in Guest Mode to see where you stand. Sign in to Mastery Mode when you’re
            ready to actually get better: the full Agora Skill Mastery engine.
          </p>
        </div>

        <div class="grid gap-5 lg:grid-cols-2">
          <!-- Guest -->
          <div
            class="reveal guest-card card-hover border-line bg-surface shadow-card flex flex-col rounded-2xl border p-7"
          >
            <span
              class="text-brand-700 bg-brand-50 border-brand-200 mb-4 inline-flex w-fit items-center rounded-full border px-3 py-1 text-xs font-bold tracking-wide uppercase"
              >Guest Mode · Free</span
            >
            <h3 class="font-display text-ink mb-2 text-xl font-bold">Test yourself in minutes</h3>
            <p class="text-muted mb-5 text-sm leading-relaxed">
              Pick any field, answer real right-and-wrong questions, and get an honest score with a
              full review. Perfect for a quick self-check or for screening a candidate or VA.
              Nothing is saved.
            </p>
            <ul class="text-body mb-6 space-y-2 text-sm">
              <li class="flex items-start gap-2">
                <span class="text-brand-500 mt-0.5">✓</span> Right/wrong questions with instant feedback
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-500 mt-0.5">✓</span> An explanation for every answer
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-500 mt-0.5">✓</span> A shareable score to benchmark your team
              </li>
            </ul>
            <button
              id="guest-choose-btn"
              type="button"
              class="border-brand-300 text-brand-700 hover:border-brand-500 hover:bg-brand-50 focus-visible:outline-brand-500 mt-auto inline-flex items-center justify-center rounded-lg border px-5 py-3 text-sm font-semibold transition-all focus-visible:outline focus-visible:outline-2"
            >
              Choose a Test
            </button>
          </div>

          <!-- Mastery -->
          <div
            class="reveal surface-dark mastery-card shadow-pop relative flex flex-col overflow-hidden rounded-2xl p-7"
            style="--reveal-delay:110ms"
          >
            <!-- Roaming green light inside the dark card -->
            <div class="aurora aurora--dark aurora--card" aria-hidden="true">
              <div class="aurora__blob aurora__blob--1"></div>
              <div class="aurora__blob aurora__blob--2"></div>
            </div>
            <span
              class="mastery-badge mb-4 inline-flex w-fit items-center rounded-full border px-3 py-1 text-xs font-bold tracking-wide uppercase"
              style="color:#bff0bd;background:rgba(79,168,74,0.14);border-color:rgba(79,168,74,0.35)"
              data-auth-label="Mastery Mode · Signed in"
              >Mastery Mode · Sign in</span
            >
            <h3 class="font-display mb-2 text-xl font-bold" style="color:#fff">
              Actually master it
            </h3>
            <p class="mb-5 text-sm leading-relaxed" style="color:rgba(215,227,218,0.85)">
              The full Skill Mastery engine: <strong style="color:#fff">541 topics</strong> across Python,
              statistics, and machine learning, with spaced-repetition drills that target your weakest
              areas, AI hints and explanations, and progress tracking over time.
            </p>
            <ul class="mb-6 space-y-2 text-sm" style="color:rgba(215,227,218,0.9)">
              <li class="flex items-start gap-2">
                <span style="color:#7ed07a" class="mt-0.5">✓</span> Priority quizzes on your weakest topics
              </li>
              <li class="flex items-start gap-2">
                <span style="color:#7ed07a" class="mt-0.5">✓</span> Progress tracking &amp; mastery scoring
              </li>
              <li class="flex items-start gap-2">
                <span style="color:#7ed07a" class="mt-0.5">✓</span> AI-generated questions &amp; “teach
                me” explanations
              </li>
            </ul>
            <a
              href={skillMasteryPath}
              class="mastery-cta bg-brand-500 shadow-glow hover:bg-brand-400 mt-auto inline-flex items-center justify-center rounded-lg px-5 py-3 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-white"
              data-auth-label="Go to Mastery Mode →"
            >
              Sign in to Mastery Mode →
            </a>
          </div>
        </div>

        <p class="text-muted mt-6 text-center text-sm">
          The <strong class="text-body">Data Science</strong> test is a live preview of the Skill Mastery
          engine: same questions, same standard. Score well, then sign in to go all the way.
        </p>
      </Container>
    </section>

    <!-- ── FILTER BAR + TEST GRID ────────────────────────────────────────── -->
    <section id="test-section" class="relative overflow-hidden py-16 lg:py-20">
      <!-- Green atmosphere: drifting aurora (masks off toward the cards) + grid -->
      <div class="aurora" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
      </div>
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-20" aria-hidden="true"></div>
      <Container class="relative z-10">
        <!-- Heading (leads the section; the controls sit beneath it) -->
        <div class="reveal relative mb-8 max-w-2xl">
          <p class="eyebrow mb-3">The tests</p>
          <h2 class="font-display text-ink mb-3 text-3xl font-bold tracking-tight lg:text-4xl">
            Choose a skill test
          </h2>
          <p class="text-muted text-lg">
            Each test checks real, technical proficiency in one field: right and wrong answers, no
            fluff.
          </p>
        </div>

        <!-- Search + field tabs. The <select> is retained (hidden) as the single
             source of truth so the existing filter logic is untouched; the pills
             simply drive it and mirror its value. -->
        <div
          class="reveal border-line bg-surface/85 shadow-card mb-10 rounded-2xl border p-3 backdrop-blur sm:p-4"
          style="--reveal-delay:80ms"
        >
          <div class="relative">
            <svg
              class="text-muted pointer-events-none absolute top-1/2 left-3.5 h-4 w-4 -translate-y-1/2"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                clip-rule="evenodd"></path>
            </svg>
            <input
              id="test-search"
              type="search"
              placeholder="Search tests..."
              class="border-line bg-canvas text-body placeholder:text-muted focus:border-brand-400 focus:ring-brand-400 w-full rounded-xl border py-3 pr-4 pl-10 text-sm focus:ring-1 focus:outline-none"
              aria-label="Search tests"
            />
          </div>

          <div
            class="filter-tabs mt-3 flex items-center gap-2 overflow-x-auto"
            role="tablist"
            aria-label="Filter tests by field"
          >
            <button
              type="button"
              role="tab"
              class="filter-pill is-active"
              data-value=""
              aria-selected="true">All fields</button
            >
            {
              quizTopics.map((t: QuizTopic) => (
                <button
                  type="button"
                  role="tab"
                  class="filter-pill"
                  data-value={t.id}
                  aria-selected="false"
                >
                  {t.shortTitle}
                </button>
              ))
            }
          </div>

          <select id="filter-topic" class="hidden" tabindex="-1" aria-hidden="true">
            <option value="">All fields</option>
            {quizTopics.map((t: QuizTopic) => <option value={t.id}>{t.shortTitle}</option>)}
          </select>
        </div>

        <!-- Test grid -->
        <div
          id="test-grid"
          class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3"
          role="list"
          aria-label="Available tests"
        >
          {
            quizTopics.map((topic: QuizTopic, i: number) => (
              <article
                class="test-card reveal group border-line bg-surface shadow-card hover:shadow-pop flex flex-col rounded-2xl border p-6 transition-all duration-200 hover:-translate-y-1"
                style={`--reveal-delay:${Math.min(i, 6) * 70}ms`}
                data-topic-id={topic.id}
                data-title={topic.shortTitle.toLowerCase()}
                role="listitem"
              >
                {/* Icon */}
                <div class="mb-4 flex items-center justify-between">
                  <div class="bg-tint inline-flex h-11 w-11 items-center justify-center rounded-xl">
                    <svg
                      class="text-brand-600 h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d={topic.iconPath} />
                    </svg>
                  </div>
                  {topic.id === 'data-science' && (
                    <span class="text-brand-700 bg-brand-50 border-brand-200 rounded-full border px-2.5 py-0.5 text-[10px] font-bold tracking-wide uppercase">
                      Skill Mastery preview
                    </span>
                  )}
                </div>

                <h3 class="font-display text-ink mb-2 text-lg font-bold">{topic.shortTitle}</h3>
                <p class="text-muted mb-4 flex-1 text-sm leading-relaxed">{topic.description}</p>

                <div class="mb-5 flex items-center gap-2">
                  {topic.availableQuestionCounts.map((n: number) => (
                    <span class="bg-canvas text-muted rounded-md px-2.5 py-1 text-xs font-medium">
                      {n} Q
                    </span>
                  ))}
                </div>

                <button
                  type="button"
                  data-topic-id={topic.id}
                  class="start-test-btn border-brand-300 text-brand-700 hover:border-brand-500 hover:bg-brand-50 hover:text-brand-700 group-hover:border-brand-500 group-hover:bg-brand-500 focus-visible:outline-brand-500 inline-flex items-center justify-center gap-1.5 rounded-lg border px-4 py-2.5 text-sm font-semibold transition-all group-hover:text-white focus-visible:outline focus-visible:outline-2"
                  aria-label={`Start ${topic.shortTitle} test`}
                >
                  Start Test
                  <svg
                    class="h-3.5 w-3.5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </button>
              </article>
            ))
          }
        </div>

        <!-- Empty state -->
        <div id="test-empty" class="hidden py-16 text-center" role="status" aria-live="polite">
          <p class="text-ink text-lg font-medium">No tests match your search.</p>
          <p class="text-muted mt-1 text-sm">Try a different search term or clear the filters.</p>
          <button
            id="clear-filters-btn"
            type="button"
            class="text-brand-600 hover:text-brand-700 mt-4 text-sm font-medium hover:underline"
          >
            Clear filters
          </button>
        </div>
      </Container>
    </section>

    <!-- ── HOW IT WORKS ───────────────────────────────────────────────────── -->
    <section class="border-line bg-canvas relative overflow-hidden border-y py-16 lg:py-20">
      <!-- Drifting green aurora + soft wash + faint grid behind the steps -->
      <div class="aurora aurora--soft" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
      </div>
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(640px 320px at 50% -8%, rgba(79,168,74,0.09), transparent 62%)"
        aria-hidden="true"
      >
      </div>
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-20" aria-hidden="true"></div>
      <Container class="relative z-10">
        <div class="reveal relative mb-10 text-center">
          <p class="eyebrow mb-3">The process</p>
          <h2 class="font-display text-ink text-3xl font-bold tracking-tight lg:text-4xl">
            How it works
          </h2>
        </div>
        <div class="steps-grid relative grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          <!-- Connector rail: shows only in the gaps between the opaque cards.
               Its green fill sweeps across when the row scrolls into view.
               Desktop-only, so it can never overlap the stacked layouts. -->
          <div class="steps-line" aria-hidden="true">
            <span class="steps-line__fill"></span>
          </div>
          {
            steps.map((step, i) => (
              <div
                class="reveal step-card border-line bg-surface shadow-card relative flex flex-col rounded-2xl border p-6"
                style={`--reveal-delay:${i * 90}ms`}
              >
                <span class="step-num font-display mb-3 block text-4xl font-bold">
                  {step.number}
                </span>
                <h3 class="font-display text-ink mb-2 text-base font-bold">{step.title}</h3>
                <p class="text-muted text-sm leading-relaxed">{step.text}</p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- ── FINAL CTA BANNER ──────────────────────────────────────────────── -->
    <section class="surface-dark cta-band relative overflow-hidden py-20 lg:py-24">
      <div class="aurora aurora--dark" aria-hidden="true">
        <div class="aurora__blob aurora__blob--1"></div>
        <div class="aurora__blob aurora__blob--2"></div>
        <div class="aurora__blob aurora__blob--3"></div>
      </div>
      <div
        class="dot-grid-dark cta-dots pointer-events-none absolute inset-0 opacity-60"
        aria-hidden="true"
      >
      </div>
      <Container>
        <div class="relative z-10 mx-auto max-w-2xl text-center">
          <h2
            class="font-display mb-4 text-3xl font-bold tracking-tight lg:text-4xl"
            style="color:#fff"
          >
            Know exactly where you, and your team, stand
          </h2>
          <p
            class="mastery-cta-copy mb-8 text-lg"
            style="color:rgba(215,227,218,0.85)"
            data-auth-label="Start free in Guest Mode. Jump into Mastery Mode to turn a score into real skill."
          >
            Start free in Guest Mode. Sign in to Mastery Mode to turn a score into real skill.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <button
              id="cta-start-btn"
              type="button"
              class="btn-sheen bg-brand-500 shadow-glow hover:bg-brand-400 inline-flex items-center rounded-lg px-8 py-3.5 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-white"
            >
              Start a Free Test
            </button>
            <a
              href={skillMasteryPath}
              class="mastery-cta inline-flex items-center rounded-lg border px-8 py-3.5 text-sm font-semibold transition-colors"
              style="color:#fff;border-color:rgba(255,255,255,0.3)"
              data-auth-label="Go to Mastery Mode →"
            >
              Sign in to Mastery Mode →
            </a>
          </div>
        </div>
      </Container>
    </section>
  </div>
  <!-- /#hub -->

  <!-- ── QUIZ OVERLAY ──────────────────────────────────────────────────────── -->
  <div
    id="quiz-overlay"
    class="bg-canvas fixed inset-0 z-[100] hidden overflow-y-auto"
    role="dialog"
    aria-modal="true"
    aria-labelledby="quiz-overlay-title"
  >
    <!-- Overlay header -->
    <div
      id="quiz-overlay-header"
      class="border-line bg-surface/95 sticky top-0 z-10 border-b backdrop-blur"
    >
      <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-4">
        <button
          id="quiz-back-btn"
          type="button"
          class="text-body hover:bg-canvas hover:text-ink focus-visible:outline-brand-500 inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2"
          aria-label="Go back"
        >
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z"
              clip-rule="evenodd"></path>
          </svg>
          Back
        </button>

        <span
          id="quiz-overlay-title"
          class="font-display text-ink text-sm font-semibold"
          aria-live="polite"></span>

        <span
          id="quiz-progress-label"
          class="text-muted text-sm"
          aria-live="polite"
          aria-atomic="true"></span>
      </div>

      <!-- Progress bar (shown only during questions) -->
      <div
        id="quiz-progress-bar-wrap"
        class="bg-brand-100 hidden h-1"
        role="progressbar"
        aria-valuenow={0}
        aria-valuemin={0}
        aria-valuemax={100}
      >
        <div
          id="quiz-progress-bar-fill"
          class="bg-brand-500 h-full transition-all duration-300"
          style="width:0%"
        >
        </div>
      </div>
    </div>

    <!-- Dynamic content area -->
    <div id="quiz-content" class="mx-auto max-w-3xl px-4 py-10 pb-20"></div>
  </div>
  <!-- /#quiz-overlay -->
</BaseLayout>

<script
  is:inline
  define:vars={{
    quizTopicsData: quizTopics,
    masteryHref: skillMasteryPath,
    hireHref: cta.becomeClient.href,
  }}
>
  // ---------------------------------------------------------------------------
  // State
  // ---------------------------------------------------------------------------
  const state = {
    topicId: quizTopicsData[0].id,
    questionCount: 10,
    sessionQuestions: [],
    currentIndex: 0,
    answers: [], // array of { selected: number, correct: boolean } | null
    phase: 'hub', // 'hub' | 'setup' | 'questions' | 'results'
  };

  // ---------------------------------------------------------------------------
  // Helpers
  // ---------------------------------------------------------------------------
  // "Quiz from my notes": an ad-hoc topic built at runtime from AI-generated
  // questions, plus its own builder state. Generic proficiency bands (the same
  // shape as the authored topics) drive the results screen.
  const notesState = { files: [], count: 8, difficulty: 'auto', authed: null };
  let customTopic = null;
  const NOTES_BANDS = [
    {
      id: 'expert',
      label: 'Strong command',
      min: 85,
      max: 100,
      summary: 'You clearly know this material well: you handled the tricky items, not just the easy recall.',
      recommendations: [
        'Push into the parts you have not written down yet, then quiz yourself on those.',
        'Teach it back or apply it to a real project to lock it in.',
        'Sign in to Mastery Mode to keep it sharp with spaced repetition.',
      ],
    },
    {
      id: 'proficient',
      label: 'Solid grasp',
      min: 70,
      max: 84,
      summary: 'A good working understanding, with a few gaps worth closing.',
      recommendations: [
        'Re-read the sections behind the questions you missed, then retake the quiz.',
        'Turn each miss into a flashcard and review it tomorrow.',
        'Sign in to Mastery Mode to drill the weak spots automatically.',
      ],
    },
    {
      id: 'developing',
      label: 'Getting there',
      min: 45,
      max: 69,
      summary: 'The basics are landing, but the material has not fully stuck yet.',
      recommendations: [
        'Study the material again in smaller chunks, then quiz one chunk at a time.',
        'Focus first on the questions you got wrong: read the explanation for each.',
        'Sign in to Mastery Mode for guided, spaced-repetition practice.',
      ],
    },
    {
      id: 'novice',
      label: 'Just starting',
      min: 0,
      max: 44,
      summary: 'This material is still new to you. That is exactly what practice is for.',
      recommendations: [
        'Work through the material once more, slowly, before testing again.',
        'Review every explanation on the results below: they are the fastest way in.',
        'Sign in to Mastery Mode to build it up from the fundamentals.',
      ],
    },
  ];

  function getTopic(id) {
    if (id === 'my-notes') return customTopic;
    return quizTopicsData.find((t) => t.id === id);
  }

  function getEstimatedTime(count) {
    if (count === 5) return '~2 min';
    if (count === 10) return '~4 min';
    return '~8 min';
  }

  function correctCount() {
    return state.answers.reduce((n, a) => n + (a && a.correct ? 1 : 0), 0);
  }

  function calculateScore() {
    const total = state.sessionQuestions.length;
    if (total === 0) return 0;
    return Math.round((correctCount() / total) * 100);
  }

  function getBand(topic, score) {
    return topic.bands.find((b) => score >= b.min && score <= b.max) ?? topic.bands[0];
  }

  function bandColorClass(bandId) {
    const map = {
      novice: { bg: '#fff3e0', text: '#b45309', border: '#fcd34d' },
      developing: { bg: '#fef9c3', text: '#a16207', border: '#fde047' },
      proficient: { bg: '#dbeafe', text: '#1d4ed8', border: '#93c5fd' },
      expert: { bg: '#dcfce7', text: '#15803d', border: '#86efac' },
    };
    return map[bandId] ?? map['developing'];
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ---------------------------------------------------------------------------
  // Lead storage (optional email report, swap body for CRM/API integration)
  // ---------------------------------------------------------------------------
  function submitQuizLead(data) {
    try {
      const existing = JSON.parse(localStorage.getItem('agora-quiz-leads') || '[]');
      existing.push({ ...data, timestamp: new Date().toISOString() });
      localStorage.setItem('agora-quiz-leads', JSON.stringify(existing));
    } catch {
      // localStorage unavailable, fail silently
    }
    // TODO: Replace or augment with an API call, e.g.:
    // fetch('/api/quiz-lead', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) })
    //   .catch(err => console.error('Lead submission error:', err));
  }

  // ---------------------------------------------------------------------------
  // Overlay open / close
  // ---------------------------------------------------------------------------
  function openOverlay() {
    const overlay = document.getElementById('quiz-overlay');
    const hub = document.getElementById('hub');
    overlay.classList.remove('hidden');
    hub.classList.add('hidden');
    document.body.style.overflow = 'hidden';
    overlay.scrollTop = 0;
    overlay.focus?.();
  }

  function closeOverlay() {
    const overlay = document.getElementById('quiz-overlay');
    const hub = document.getElementById('hub');
    overlay.classList.add('hidden');
    hub.classList.remove('hidden');
    document.body.style.overflow = '';
    state.phase = 'hub';
  }

  function setOverlayTitle(text) {
    document.getElementById('quiz-overlay-title').textContent = text;
  }

  function setProgressLabel(text) {
    document.getElementById('quiz-progress-label').textContent = text;
  }

  function setProgressBar(fraction) {
    const wrap = document.getElementById('quiz-progress-bar-wrap');
    const fill = document.getElementById('quiz-progress-bar-fill');
    if (fraction === null) {
      wrap.classList.add('hidden');
    } else {
      wrap.classList.remove('hidden');
      const pct = Math.round(fraction * 100);
      fill.style.width = pct + '%';
      wrap.setAttribute('aria-valuenow', pct);
    }
  }

  // ---------------------------------------------------------------------------
  // Screen: Setup
  // ---------------------------------------------------------------------------
  function showSetupScreen(topicId) {
    const topic = getTopic(topicId);
    if (!topic) return;
    state.topicId = topicId;
    state.phase = 'setup';
    openOverlay();
    setOverlayTitle(topic.shortTitle);
    setProgressLabel('');
    setProgressBar(null);

    const isDs = topic.id === 'data-science';

    const content = document.getElementById('quiz-content');
    content.innerHTML = `
      <div class="mx-auto max-w-xl text-center">
        <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-tint">
          <svg class="h-8 w-8 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="${topic.iconPath}" />
          </svg>
        </div>
        <h2 class="font-display mb-3 text-2xl font-bold tracking-tight text-ink lg:text-3xl">${escapeHtml(topic.title)}</h2>
        <p class="mb-2 text-base leading-relaxed text-muted">${escapeHtml(topic.description)}</p>
        <p class="mb-10 text-sm text-muted">Real questions. One right answer each. You’ll see the correct answer and why, after every question.</p>

        <div class="mb-8">
          <p class="mb-3 text-sm font-semibold text-ink">How many questions?</p>
          <div class="flex justify-center gap-3" id="setup-count-group" role="group" aria-label="Number of questions">
            ${topic.availableQuestionCounts
              .map(
                (n) => `
              <button type="button" data-count="${n}"
                class="setup-count-btn w-24 rounded-xl border-2 py-3 text-sm font-semibold transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-500
                  ${n === state.questionCount ? 'border-brand-500 bg-brand-50 text-brand-700' : 'border-line text-body hover:border-brand-300 hover:bg-brand-50'}"
                aria-pressed="${n === state.questionCount}">
                <span class="block text-xl font-bold">${n}</span>
                <span class="block text-xs font-normal text-muted">${getEstimatedTime(n)}</span>
              </button>`,
              )
              .join('')}
          </div>
        </div>

        <button id="setup-start-btn" type="button"
          class="inline-flex w-full max-w-xs items-center justify-center rounded-xl bg-brand-500 py-3.5 text-sm font-semibold text-white shadow-glow-sm transition-colors hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-500">
          Start Test
        </button>
        <p class="mt-3 text-xs text-muted">Free · No sign-up · Nothing saved</p>
        ${
          isDs
            ? `<p class="mt-6 text-xs text-muted">This is a live preview of the <a href="${masteryHref}" class="font-medium text-brand-600 underline hover:text-brand-700">Skill Mastery engine</a>, 541 topics, spaced repetition, and AI tutoring in Mastery Mode.</p>`
            : ''
        }
      </div>
    `;

    // Setup count buttons
    content.querySelectorAll('.setup-count-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const n = parseInt(btn.dataset.count, 10);
        state.questionCount = n;
        content.querySelectorAll('.setup-count-btn').forEach((b) => {
          const active = parseInt(b.dataset.count, 10) === n;
          b.className = b.className
            .replace(
              /border-brand-500 bg-brand-50 text-brand-700|border-line text-body hover:border-brand-300 hover:bg-brand-50/g,
              '',
            )
            .trim();
          b.classList.add(
            ...(active
              ? ['border-brand-500', 'bg-brand-50', 'text-brand-700']
              : ['border-line', 'text-body', 'hover:border-brand-300', 'hover:bg-brand-50']),
          );
          b.setAttribute('aria-pressed', String(active));
        });
      });
    });

    document.getElementById('setup-start-btn').addEventListener('click', () => {
      startQuiz(state.topicId, state.questionCount);
    });
  }

  // ---------------------------------------------------------------------------
  // Screen: Quiz from my notes (builder)
  // ---------------------------------------------------------------------------
  function fmtBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1024 * 1024) return Math.round(b / 1024) + ' KB';
    return (b / 1024 / 1024).toFixed(1) + ' MB';
  }
  function fileGlyph(f) {
    const n = (f.name || '').toLowerCase();
    const m = (f.type || '').toLowerCase();
    if (m.startsWith('image/') || /\.(png|jpe?g|webp|gif|heic|heif)$/.test(n)) return '🖼️';
    if (m === 'application/pdf' || /\.pdf$/.test(n)) return '📄';
    return '📝';
  }
  const NOTES_MAX_FILES = 12;
  const NOTES_MAX_BYTES = 16 * 1024 * 1024;

  function renderNotesFileList() {
    const wrap = document.getElementById('notes-file-list');
    if (!wrap) return;
    if (!notesState.files.length) {
      wrap.innerHTML = '';
      wrap.classList.add('hidden');
      return;
    }
    wrap.classList.remove('hidden');
    wrap.innerHTML = notesState.files
      .map(
        (f, i) => `
      <div class="flex items-center gap-3 rounded-xl border border-line bg-surface px-4 py-2.5">
        <span class="text-base leading-none" aria-hidden="true">${fileGlyph(f)}</span>
        <span class="min-w-0 flex-1 truncate text-sm font-medium text-ink" title="${escapeHtml(f.name)}">${escapeHtml(f.name)}</span>
        <span class="text-xs text-muted">${fmtBytes(f.size)}</span>
        <button type="button" data-remove="${i}" class="notes-file-x flex h-6 w-6 items-center justify-center rounded-lg bg-canvas text-muted transition-colors hover:bg-red-50 hover:text-red-600" aria-label="Remove ${escapeHtml(f.name)}">×</button>
      </div>`,
      )
      .join('');
    wrap.querySelectorAll('.notes-file-x').forEach((btn) => {
      btn.addEventListener('click', () => {
        notesState.files.splice(parseInt(btn.dataset.remove, 10), 1);
        renderNotesFileList();
      });
    });
  }

  function addNotesFiles(fileList) {
    const errEl = document.getElementById('notes-error');
    if (errEl) errEl.textContent = '';
    for (const f of Array.from(fileList || [])) {
      if (notesState.files.length >= NOTES_MAX_FILES) {
        if (errEl) errEl.textContent = `You can add up to ${NOTES_MAX_FILES} files.`;
        break;
      }
      if (f.size > NOTES_MAX_BYTES) {
        if (errEl) errEl.textContent = `"${f.name}" is over 16 MB and was skipped.`;
        continue;
      }
      notesState.files.push(f);
    }
    renderNotesFileList();
  }

  function showNotesSetupScreen() {
    state.phase = 'notes-setup';
    state.topicId = 'my-notes';
    notesState.files = [];
    openOverlay();
    setOverlayTitle('Quiz from my notes');
    setProgressLabel('');
    setProgressBar(null);

    const countOpts = [5, 10, 20];
    const diffOpts = [
      ['auto', 'Auto'],
      ['core', 'Core'],
      ['balanced', 'Balanced'],
      ['challenge', 'Challenge'],
    ];
    const content = document.getElementById('quiz-content');
    content.innerHTML = `
      <div class="mx-auto max-w-xl">
        <div class="mb-6 text-center">
          <div class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-tint">
            <svg class="h-7 w-7 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M12 18v-6"/><path d="M9.5 14.5 12 12l2.5 2.5"/>
            </svg>
          </div>
          <h2 class="font-display mb-2 text-2xl font-bold tracking-tight text-ink lg:text-3xl">Quiz from my notes</h2>
          <p class="text-sm leading-relaxed text-muted">Upload documents or paste text. The Skill Mastery engine writes a quiz on exactly that material, with an explanation after every question.</p>
        </div>

        <div id="notes-auth-note" class="mb-5 hidden rounded-xl border px-4 py-3 text-sm"></div>

        <label id="notes-drop" for="notes-files" class="mb-3 flex cursor-pointer flex-col items-center gap-1.5 rounded-2xl border-2 border-dashed border-line bg-canvas px-6 py-8 text-center transition-colors hover:border-brand-400 hover:bg-brand-50">
          <input type="file" id="notes-files" multiple class="hidden"
            accept=".pdf,.png,.jpg,.jpeg,.webp,.gif,.heic,.txt,.text,.md,.markdown,.csv,.tsv,.json,.yaml,.yml,.html,.htm,.tex,.rst,.log,application/pdf,image/*,text/*" />
          <svg class="h-9 w-9 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 16V4"/><path d="m7 9 5-5 5 5"/><path d="M5 20h14"/></svg>
          <span class="text-sm text-ink"><strong>Click to choose files</strong> or drop them here</span>
          <span class="text-xs text-muted">PDF, images (png/jpg), or text/markdown, up to 12 files</span>
        </label>
        <div id="notes-file-list" class="mb-4 hidden space-y-2"></div>

        <div class="my-4 flex items-center gap-3 text-xs font-semibold uppercase tracking-wide text-muted">
          <span class="h-px flex-1 bg-line"></span>and / or<span class="h-px flex-1 bg-line"></span>
        </div>

        <label class="mb-1.5 block text-sm font-semibold text-ink" for="notes-text">Paste text</label>
        <textarea id="notes-text" rows="5" class="mb-5 w-full rounded-xl border border-line bg-surface px-4 py-3 text-sm leading-relaxed text-body placeholder:text-muted focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-100"
          placeholder="Paste your notes, an article, definitions, a transcript, anything you want to be quizzed on."></textarea>

        <div class="mb-5">
          <p class="mb-2 text-sm font-semibold text-ink">How many questions?</p>
          <div class="flex gap-2" id="notes-count-group" role="group" aria-label="Number of questions">
            ${countOpts
              .map(
                (n) => `<button type="button" data-count="${n}" class="notes-count-btn flex-1 rounded-xl border-2 py-2.5 text-sm font-semibold transition-all ${
                  n === notesState.count
                    ? 'border-brand-500 bg-brand-50 text-brand-700'
                    : 'border-line text-body hover:border-brand-300 hover:bg-brand-50'
                }" aria-pressed="${n === notesState.count}">${n}</button>`,
              )
              .join('')}
          </div>
        </div>

        <div class="mb-5">
          <p class="mb-2 text-sm font-semibold text-ink">Difficulty</p>
          <div class="flex flex-wrap gap-2" id="notes-diff-group" role="group" aria-label="Difficulty">
            ${diffOpts
              .map(
                ([v, label]) => `<button type="button" data-diff="${v}" class="notes-diff-btn rounded-xl border-2 px-4 py-2 text-sm font-semibold transition-all ${
                  v === notesState.difficulty
                    ? 'border-brand-500 bg-brand-50 text-brand-700'
                    : 'border-line text-body hover:border-brand-300 hover:bg-brand-50'
                }" aria-pressed="${v === notesState.difficulty}">${label}</button>`,
              )
              .join('')}
          </div>
        </div>

        <label class="mb-1.5 block text-sm font-semibold text-ink" for="notes-context">Extra instructions for the AI <span class="font-normal text-muted">(optional)</span></label>
        <textarea id="notes-context" rows="2" class="mb-6 w-full rounded-xl border border-line bg-surface px-4 py-3 text-sm leading-relaxed text-body placeholder:text-muted focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-100"
          placeholder="e.g. Focus on chapter 3, quiz me on the formulas only, or keep it applied to real scenarios."></textarea>

        <button id="notes-generate-btn" type="button"
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-500 py-3.5 text-sm font-semibold text-white shadow-glow-sm transition-colors hover:bg-brand-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-500">
          Create my quiz
        </button>
        <div id="notes-loader" class="mt-4 hidden items-center justify-center gap-3 text-sm text-muted">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-brand-200 border-t-brand-500"></span>
          <span>Reading your material and writing questions...</span>
        </div>
        <p id="notes-error" class="mt-3 text-center text-sm text-red-600"></p>
      </div>
    `;

    // Count buttons
    content.querySelectorAll('.notes-count-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        notesState.count = parseInt(btn.dataset.count, 10);
        content.querySelectorAll('.notes-count-btn').forEach((b) => {
          const on = parseInt(b.dataset.count, 10) === notesState.count;
          b.classList.toggle('border-brand-500', on);
          b.classList.toggle('bg-brand-50', on);
          b.classList.toggle('text-brand-700', on);
          b.classList.toggle('border-line', !on);
          b.classList.toggle('text-body', !on);
          b.setAttribute('aria-pressed', String(on));
        });
      });
    });
    // Difficulty buttons
    content.querySelectorAll('.notes-diff-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        notesState.difficulty = btn.dataset.diff;
        content.querySelectorAll('.notes-diff-btn').forEach((b) => {
          const on = b.dataset.diff === notesState.difficulty;
          b.classList.toggle('border-brand-500', on);
          b.classList.toggle('bg-brand-50', on);
          b.classList.toggle('text-brand-700', on);
          b.classList.toggle('border-line', !on);
          b.classList.toggle('text-body', !on);
          b.setAttribute('aria-pressed', String(on));
        });
      });
    });
    // File input + drag/drop
    document.getElementById('notes-files').addEventListener('change', (e) => {
      addNotesFiles(e.target.files);
      e.target.value = '';
    });
    const drop = document.getElementById('notes-drop');
    ['dragenter', 'dragover'].forEach((ev) =>
      drop.addEventListener(ev, (e) => {
        e.preventDefault();
        drop.classList.add('border-brand-400', 'bg-brand-50');
      }),
    );
    ['dragleave', 'dragend'].forEach((ev) =>
      drop.addEventListener(ev, () => drop.classList.remove('border-brand-400', 'bg-brand-50')),
    );
    drop.addEventListener('drop', (e) => {
      e.preventDefault();
      drop.classList.remove('border-brand-400', 'bg-brand-50');
      if (e.dataTransfer && e.dataTransfer.files) addNotesFiles(e.dataTransfer.files);
    });

    document.getElementById('notes-generate-btn').addEventListener('click', generateNotesQuiz);
    renderNotesFileList();
    applyNotesAuthState();
  }

  // Reflect sign-in state: gate generation behind the shared Mastery login.
  function applyNotesAuthState() {
    const note = document.getElementById('notes-auth-note');
    const btn = document.getElementById('notes-generate-btn');
    if (!note || !btn) return;
    const render = (authed) => {
      notesState.authed = authed;
      if (authed) {
        note.classList.add('hidden');
        btn.disabled = false;
        btn.textContent = 'Create my quiz';
      } else {
        note.className = 'mb-5 rounded-xl border border-brand-200 bg-brand-50 px-4 py-3 text-sm text-body';
        note.innerHTML = `Generating a quiz from your material uses the Skill Mastery engine, so it needs a <a href="${masteryHref}" class="font-semibold text-brand-700 underline hover:text-brand-800">Mastery sign-in</a>. Sign in, then come back here.`;
        note.classList.remove('hidden');
      }
    };
    if (notesState.authed !== null) {
      render(notesState.authed);
      return;
    }
    fetch('/api/me', { credentials: 'same-origin' })
      .then((r) => r.json())
      .then((me) => render(!!(me && me.authed)))
      .catch(() => render(true)); // network hiccup: don't block; the endpoint still enforces auth
  }

  async function generateNotesQuiz() {
    const text = (document.getElementById('notes-text').value || '').trim();
    const errEl = document.getElementById('notes-error');
    errEl.textContent = '';
    if (!notesState.files.length && !text) {
      errEl.textContent = 'Add at least one file or paste some text first.';
      return;
    }
    if (notesState.authed === false) {
      applyNotesAuthState();
      return;
    }
    const btn = document.getElementById('notes-generate-btn');
    const loader = document.getElementById('notes-loader');
    btn.disabled = true;
    loader.classList.remove('hidden');
    loader.classList.add('flex');

    try {
      // Read files to base64 and send JSON (not multipart): Astro's checkOrigin
      // CSRF guard only inspects form content-types and mis-fires behind Cloud
      // Run's TLS proxy, so a form POST is wrongly 403'd; JSON is exempt + safe.
      const files = await Promise.all(
        notesState.files.map(
          (f) =>
            new Promise((resolve, reject) => {
              const r = new FileReader();
              r.onload = () => {
                const s = String(r.result || '');
                const comma = s.indexOf(',');
                resolve({ name: f.name, mime: f.type || '', dataBase64: comma >= 0 ? s.slice(comma + 1) : s });
              };
              r.onerror = () => reject(r.error || new Error('read failed'));
              r.readAsDataURL(f);
            }),
        ),
      );
      const res = await fetch('/api/notes-quiz', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          text,
          files,
          count: notesState.count,
          difficulty: notesState.difficulty,
          extraContext: (document.getElementById('notes-context').value || '').trim(),
        }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.status === 401) {
        notesState.authed = false;
        applyNotesAuthState();
        return;
      }
      if (!res.ok || !data.ok) throw new Error(data.error || `Request failed (${res.status})`);
      if (!Array.isArray(data.questions) || !data.questions.length) {
        throw new Error('No questions came back. Try adding more material.');
      }

      // Build the ad-hoc topic and run it through the normal quiz flow.
      const label = data.sourceLabel || 'My notes';
      customTopic = {
        id: 'my-notes',
        title: 'Quiz from my notes',
        shortTitle: label.length > 32 ? label.slice(0, 31) + '…' : label,
        description: 'A quiz generated from your own material.',
        iconPath: 'M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z',
        availableQuestionCounts: [data.questions.length],
        questions: data.questions,
        bands: NOTES_BANDS,
      };
      startQuiz('my-notes', data.questions.length);
    } catch (e) {
      errEl.textContent = 'Could not build the quiz: ' + (e && e.message ? e.message : e);
    } finally {
      btn.disabled = false;
      loader.classList.add('hidden');
      loader.classList.remove('flex');
    }
  }

  // ---------------------------------------------------------------------------
  // Screen: Questions
  // ---------------------------------------------------------------------------
  function startQuiz(topicId, count) {
    const topic = getTopic(topicId);
    if (!topic) return;
    state.topicId = topicId;
    state.questionCount = count;
    state.sessionQuestions = topic.questions.slice(0, count);
    state.currentIndex = 0;
    state.answers = new Array(state.sessionQuestions.length).fill(null);
    state.phase = 'questions';
    if (
      state.phase === 'questions' &&
      document.getElementById('quiz-overlay').classList.contains('hidden')
    ) {
      openOverlay();
    }
    renderQuestion();
  }

  function renderQuestion() {
    const topic = getTopic(state.topicId);
    const q = state.sessionQuestions[state.currentIndex];
    const total = state.sessionQuestions.length;
    const idx = state.currentIndex;

    setOverlayTitle(topic.shortTitle);
    setProgressLabel(`Question ${idx + 1} of ${total}`);
    setProgressBar(idx / total);

    const answered = state.answers[idx];
    const isLast = idx === total - 1;

    const content = document.getElementById('quiz-content');
    content.innerHTML = `
      <div class="mx-auto max-w-2xl">
        <p class="mb-3 text-sm font-medium text-muted">Question ${idx + 1} of ${total}</p>
        <h2 class="font-display mb-8 text-xl font-bold leading-snug text-ink lg:text-2xl">${escapeHtml(q.question)}</h2>

        <div class="mb-6 space-y-3" id="options-list" role="listbox" aria-label="Answer options">
          ${q.options
            .map(
              (opt, i) => `
            <button type="button" data-index="${i}"
              role="option" aria-selected="false"
              class="option-btn w-full rounded-xl border-2 border-line bg-surface px-5 py-4 text-left text-sm leading-relaxed text-body transition-all hover:border-brand-300 hover:bg-brand-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-500">
              <span class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border-2 border-current text-xs font-bold option-indicator">
                  ${String.fromCharCode(65 + i)}
                </span>
                <span>${escapeHtml(opt)}</span>
              </span>
            </button>`,
            )
            .join('')}
        </div>

        <div id="explain-area" class="mb-8 hidden rounded-xl border border-line bg-canvas px-5 py-4">
          <p id="explain-verdict" class="mb-1 text-sm font-bold"></p>
          <p id="explain-text" class="text-sm leading-relaxed text-body"></p>
        </div>

        <div class="flex items-center justify-between">
          ${idx > 0 ? `<button id="quiz-prev-btn" type="button" class="rounded-lg px-4 py-2.5 text-sm font-medium text-body hover:bg-canvas focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-500">← Previous</button>` : '<span></span>'}
          <button id="quiz-next-btn" type="button" disabled
            class="inline-flex items-center gap-1.5 rounded-lg bg-brand-500 px-6 py-2.5 text-sm font-semibold text-white shadow-glow-sm transition-all hover:bg-brand-600 disabled:cursor-not-allowed disabled:opacity-40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-500">
            ${isLast ? 'See Results' : 'Next Question'} →
          </button>
        </div>
      </div>
    `;

    const buttons = Array.from(content.querySelectorAll('.option-btn'));

    // Option selection (only if not yet answered)
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (state.answers[idx]) return; // already answered, locked
        const chosen = parseInt(btn.dataset.index, 10);
        state.answers[idx] = { selected: chosen, correct: chosen === q.correctIndex };
        applyAnswerVisual(q, state.answers[idx]);
      });
    });

    // Restore an already-answered question (e.g. after Previous)
    if (answered) {
      applyAnswerVisual(q, answered);
    }

    // Next
    document.getElementById('quiz-next-btn').addEventListener('click', () => {
      if (!state.answers[idx]) return;
      if (!isLast) {
        state.currentIndex++;
        document.getElementById('quiz-overlay').scrollTop = 0;
        renderQuestion();
      } else {
        showResults();
      }
    });

    // Prev
    document.getElementById('quiz-prev-btn')?.addEventListener('click', () => {
      if (state.currentIndex > 0) {
        state.currentIndex--;
        document.getElementById('quiz-overlay').scrollTop = 0;
        renderQuestion();
      }
    });
  }

  // Lock the options, reveal correct/incorrect + explanation, enable Next.
  function applyAnswerVisual(q, answer) {
    const content = document.getElementById('quiz-content');
    const buttons = Array.from(content.querySelectorAll('.option-btn'));

    buttons.forEach((btn) => {
      const i = parseInt(btn.dataset.index, 10);
      btn.disabled = true;
      btn.classList.remove('hover:border-brand-300', 'hover:bg-brand-50');
      const ind = btn.querySelector('.option-indicator');
      if (i === q.correctIndex) {
        btn.classList.remove('border-line', 'bg-surface');
        btn.classList.add('border-green-500', 'bg-green-50', 'text-green-800');
        if (ind) ind.classList.add('bg-green-500', 'border-green-500', 'text-white');
      } else if (i === answer.selected) {
        btn.classList.remove('border-line', 'bg-surface');
        btn.classList.add('border-red-400', 'bg-red-50', 'text-red-700');
        if (ind) ind.classList.add('bg-red-500', 'border-red-500', 'text-white');
      } else {
        btn.classList.add('opacity-60');
      }
      btn.setAttribute('aria-selected', String(i === answer.selected));
    });

    const area = document.getElementById('explain-area');
    const verdict = document.getElementById('explain-verdict');
    const text = document.getElementById('explain-text');
    area.classList.remove('hidden');
    if (answer.correct) {
      verdict.textContent = 'Correct ✓';
      verdict.style.color = '#15803d';
    } else {
      verdict.textContent = 'Not quite. Answer: ' + q.options[q.correctIndex];
      verdict.style.color = '#b91c1c';
    }
    text.textContent = q.explanation || '';

    document.getElementById('quiz-next-btn').disabled = false;
  }

  // ---------------------------------------------------------------------------
  // Screen: Results
  // ---------------------------------------------------------------------------
  function showResults() {
    const topic = getTopic(state.topicId);
    const total = state.sessionQuestions.length;
    const correct = correctCount();
    const score = calculateScore();
    const band = getBand(topic, score);
    const colors = bandColorClass(band.id);
    const circumference = 2 * Math.PI * 40;
    const offset = circumference * (1 - score / 100);
    state.phase = 'results';
    const isDs = topic.id === 'data-science';

    setOverlayTitle(topic.shortTitle);
    setProgressLabel('Your results');
    setProgressBar(null);

    const breakdownRows = state.sessionQuestions
      .map((q, i) => {
        const a = state.answers[i];
        const ok = a && a.correct;
        return `
        <div class="flex items-start gap-3 rounded-xl border border-line bg-surface px-4 py-3">
          <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full text-xs font-bold"
            style="background:${ok ? '#dcfce7' : '#fee2e2'};color:${ok ? '#15803d' : '#b91c1c'}">
            ${ok ? '✓' : '✕'}
          </span>
          <div class="min-w-0">
            <p class="text-sm font-medium text-ink">${escapeHtml(q.question)}</p>
            ${
              ok
                ? ''
                : `<p class="mt-1 text-xs text-muted"><span class="font-semibold text-body">Correct:</span> ${escapeHtml(q.options[q.correctIndex])}</p>`
            }
            <p class="mt-1 text-xs leading-relaxed text-muted">${escapeHtml(q.explanation || '')}</p>
          </div>
        </div>`;
      })
      .join('');

    const content = document.getElementById('quiz-content');
    content.innerHTML = `
      <div class="mx-auto max-w-2xl">
        <!-- Score card -->
        <div class="mb-8 overflow-hidden rounded-2xl border border-line bg-surface shadow-pop">
          <div class="flex flex-col items-center gap-6 p-8 sm:flex-row">
            <!-- Score ring -->
            <div class="flex-shrink-0">
              <svg width="100" height="100" viewBox="0 0 100 100" aria-label="${score} percent" role="img">
                <circle cx="50" cy="50" r="40" fill="none" stroke="#e6e6e9" stroke-width="8"/>
                <circle cx="50" cy="50" r="40" fill="none" stroke="#4fa84a" stroke-width="8"
                  stroke-dasharray="${circumference}"
                  stroke-dashoffset="${offset}"
                  stroke-linecap="round"
                  transform="rotate(-90 50 50)"
                  style="transition:stroke-dashoffset 0.8s cubic-bezier(.22,1,.36,1)"/>
                <text x="50" y="54" text-anchor="middle" font-family="Archivo Variable, Archivo, sans-serif" font-size="22" font-weight="700" fill="#121212">${score}%</text>
                <text x="50" y="67" text-anchor="middle" font-family="Lato, sans-serif" font-size="10" fill="#6b6f6c">${correct}/${total}</text>
              </svg>
            </div>

            <div class="text-center sm:text-left">
              <p class="mb-1 text-sm text-muted">${escapeHtml(topic.shortTitle)} · ${correct} of ${total} correct</p>
              <h2 class="font-display mb-3 text-2xl font-bold tracking-tight text-ink lg:text-3xl">${score}%</h2>
              <span class="inline-block rounded-full px-4 py-1.5 text-sm font-semibold"
                style="background:${colors.bg};color:${colors.text};border:1px solid ${colors.border}">
                ${escapeHtml(band.label)}
              </span>
            </div>
          </div>

          <div class="border-t border-line px-8 py-6">
            <p class="text-base leading-relaxed text-body">${escapeHtml(band.summary)}</p>
          </div>
        </div>

        <!-- Recommendations -->
        <div class="mb-8">
          <h3 class="font-display mb-4 text-xl font-bold text-ink">How to level up</h3>
          <div class="space-y-3">
            ${band.recommendations
              .map(
                (rec, i) => `
              <div class="flex items-start gap-3 rounded-xl border border-line bg-surface px-5 py-4">
                <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">${i + 1}</span>
                <p class="text-sm leading-relaxed text-body">${escapeHtml(rec)}</p>
              </div>`,
              )
              .join('')}
          </div>
        </div>

        <!-- Mastery Mode CTA -->
        <div class="mb-8 rounded-2xl p-6 surface-dark">
          <h3 class="font-display mb-1 text-lg font-bold" style="color:#fff">${
            isDs ? 'Go all the way with Mastery Mode' : 'Ready to actually master this?'
          }</h3>
          <p class="mb-4 text-sm leading-relaxed" style="color:rgba(215,227,218,0.85)">
            ${
              isDs
                ? 'This was a preview. Sign in to the full Skill Mastery engine: 541 topics, spaced-repetition drills on your weakest areas, AI hints, and progress tracking.'
