---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import SectionHeading from '@components/SectionHeading.astro';
import Button from '@components/Button.astro';
import { caseStudies, competitions } from '@data/portfolio';
import { getCollection } from 'astro:content';

export const prerender = true;

// Narrative case studies authored as Markdown posts (type: 'case-study').
// They keep their original article URL but are surfaced here, not in the blog.
const postCaseStudies = (
  await getCollection('posts', ({ data }) => !data.draft && data.type === 'case-study')
).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Portfolio"
  description="Real-life results from Agora Data Driven: client case studies and award-winning analytics competition placements."
>
  <section class="border-line from-tint/50 to-canvas border-b bg-linear-to-b">
    <Container class="py-16 lg:py-24">
      <p class="text-brand-600 text-sm font-semibold tracking-wide uppercase">Portfolio</p>
      <h1 class="text-ink mt-2 max-w-3xl text-4xl font-bold sm:text-5xl">Explore our portfolio</h1>
      <p class="text-muted mt-4 max-w-2xl text-lg">
        Our portfolio isn't just a list of projects, it's proof of how we solve problems, drive
        growth, and adapt fast. Every campaign reflects a challenge we've tackled, a strategy we've
        shaped, and the results we've delivered.
      </p>
    </Container>
  </section>

  <!-- Case studies -->
  <section id="case-studies" class="border-line border-b py-16 lg:py-24">
    <Container>
      <SectionHeading eyebrow="Case studies" title="Real-life results">
        <p class="text-muted mt-3">
          From concept to execution, each case shows our problem-solving approach and results-driven
          mindset.
        </p>
      </SectionHeading>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          postCaseStudies.map((post, i) => (
            <article
              class="card-hover reveal border-line bg-surface shadow-card hover:shadow-pop flex flex-col overflow-hidden rounded-2xl border transition-all duration-300"
              style={`--reveal-delay: ${i * 80}ms`}
            >
              {post.data.heroImage && (
                <a href={`/${post.id}/`} class="bg-canvas block overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt=""
                    class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="flex flex-1 flex-col p-6">
                <span class="bg-tint text-brand-700 w-fit rounded-full px-3 py-1 text-xs font-semibold">
                  Case Study
                </span>
                <h3 class="text-ink mt-3 text-xl font-semibold">{post.data.title}</h3>
                <p class="text-muted mt-2 flex-1 text-sm">{post.data.excerpt}</p>
                <a
                  href={`/${post.id}/`}
                  class="text-brand-600 hover:text-brand-700 mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors"
                >
                  Read the story
                  <span
                    class="transition-transform duration-200 group-hover:translate-x-1"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              </div>
            </article>
          ))
        }
        {
          caseStudies.map((c, i) => (
            <article
              class="card-hover reveal border-line bg-surface shadow-card hover:shadow-pop flex flex-col overflow-hidden rounded-2xl border transition-all duration-300"
              style={`--reveal-delay: ${(postCaseStudies.length + i) * 80}ms`}
            >
              <a href={`/${c.slug}/`} class="bg-canvas block overflow-hidden">
                <img
                  src={c.cardImage ?? c.image ?? c.heroImage}
                  alt=""
                  class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </a>
              <div class="flex flex-1 flex-col p-6">
                <span class="bg-tint text-brand-700 w-fit rounded-full px-3 py-1 text-xs font-semibold">
                  {c.tag}
                </span>
                <h3 class="text-ink mt-3 text-xl font-semibold">{c.cardTitle}</h3>
                <p class="text-muted mt-2 flex-1 text-sm">{c.summary}</p>
                <a
                  href={`/${c.slug}/`}
                  class="text-brand-600 hover:text-brand-700 mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors"
                >
                  Learn more
                  <span
                    class="transition-transform duration-200 group-hover:translate-x-1"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Competitions -->
  <section id="competitions" class="border-line bg-surface border-b py-16 lg:py-24">
    <Container>
      <SectionHeading eyebrow="Competitions" title="Skill meets growth">
        <p class="text-muted mt-3">
          We regularly enter industry analytics challenges to stay sharp, and we win.
        </p>
      </SectionHeading>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          competitions.map((c, i) => (
            <a
              href={`/${c.slug}/`}
              class="card-hover reveal border-line bg-canvas hover:shadow-pop shadow-card flex flex-col rounded-2xl border p-7 transition-all duration-300"
              style={`--reveal-delay: ${i * 80}ms`}
            >
              <span class="text-brand-600 text-3xl font-bold">{c.placement}</span>
              <h3 class="text-ink mt-3 text-xl font-semibold">{c.cardTitle}</h3>
              <p class="text-muted mt-2 text-sm">{c.event}</p>
              <span class="text-brand-600 mt-4 inline-flex items-center gap-1 text-sm font-semibold">
                See the project <span aria-hidden="true">&rarr;</span>
              </span>
            </a>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Web development -->
  <section class="py-16 lg:py-24">
    <Container>
      <div
        class="border-line bg-surface flex flex-col items-start justify-between gap-6 rounded-2xl border p-8 lg:flex-row lg:items-center"
      >
        <div>
          <h2 class="text-ink text-2xl font-bold">Looking for high-performance web development?</h2>
          <p class="text-muted mt-2 max-w-2xl">
            We build fast, responsive, conversion-focused business websites using modern stacks like
            React, Vite, and WordPress.
          </p>
        </div>
        <Button href="https://webdev.agoradatadriven.com/" external variant="secondary" size="lg">
          View web development
        </Button>
      </div>
    </Container>
  </section>
</BaseLayout>
