---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import StatBand from '@components/home/StatBand.astro';
import Certifications from '@components/home/Certifications.astro';
import ValueProps from '@components/home/ValueProps.astro';
import Testimonials from '@components/home/Testimonials.astro';
import PortfolioTeaser from '@components/home/PortfolioTeaser.astro';
import LatestPosts from '@components/home/LatestPosts.astro';
import Faq from '@components/home/Faq.astro';
import QuoteCta from '@components/home/QuoteCta.astro';

// Server-rendered (not prerendered) so the in-page website editor can read the ag_sso admin cookie
// at request time — the home page is the editor's landing (open it with ?edit=1). Output is the same
// HTML as before; it's just rendered per request instead of at build.
export const prerender = false;
---

<BaseLayout>
  <Hero />
  <StatBand />
  <Certifications />
  <ValueProps />
  <Testimonials />
  <PortfolioTeaser />
  <LatestPosts />
  <Faq />
  <QuoteCta />
</BaseLayout>
