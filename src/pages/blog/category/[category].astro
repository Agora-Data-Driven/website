---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Button from '@components/Button.astro';
import { getCollection } from 'astro:content';
import { silos, type Silo } from '@data/categories';
import { cta } from '@data/cta';
import { skillMasteryUrl } from '@data/nav';

export const prerender = true;

// One crawlable hub page per silo that actually has published posts, empty
// silos are intentionally not rendered (no thin/empty category pages).
export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.type === 'post');
  const used = new Set(posts.map((p) => p.data.category));
  return silos
    .filter((s) => used.has(s.name))
    .map((s) => ({ params: { category: s.slug }, props: { silo: s } }));
}

interface Props {
  silo: Silo;
}
const { silo } = Astro.props;

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.type === 'post');

const posts = allPosts
  .filter((p) => p.data.category === silo.name)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Sibling silos that have content, for cross-linking ("link like clusters").
const populated = new Set(allPosts.map((p) => p.data.category));
const siblings = silos.filter((s) => s.slug !== silo.slug && populated.has(s.name));

const isTalent = silo.audience === 'talent';
---

<BaseLayout title={`${silo.name} | Blog`} description={silo.metaDescription}>
  <section class="border-line from-tint/40 to-canvas border-b bg-linear-to-b">
    <Container class="py-12 lg:py-16">
      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Blog', href: '/blog/' },
          { label: silo.name },
        ]}
      />
      <p class="eyebrow mt-6">Blog topic</p>
      <h1 class="text-ink mt-2 text-4xl font-bold sm:text-5xl">{silo.name}</h1>
      <p class="text-muted mt-3 max-w-2xl text-lg">{silo.tagline}</p>
    </Container>
  </section>

  <Container class="py-12 lg:py-16">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article class="border-line bg-surface shadow-card card-hover flex flex-col rounded-2xl border p-6">
            <p class="text-brand-600 text-xs font-semibold tracking-wide uppercase">
              {post.data.category}
            </p>
            <h2 class="text-ink mt-2 text-lg font-semibold">
              <a href={`/${post.id}/`} class="hover:text-brand-700">
                {post.data.title}
              </a>
            </h2>
            <p class="text-muted mt-2 flex-1 text-sm">{post.data.excerpt}</p>
            <p class="text-muted mt-4 text-xs">{fmt(post.data.publishDate)}</p>
          </article>
        ))
      }
    </div>

    {/* Audience-aware CTA */}
    <div class="border-line bg-surface mt-12 rounded-2xl border p-8 text-center">
      {
        isTalent ? (
          <>
            <h2 class="text-ink text-2xl font-bold">Want to build these skills for real?</h2>
            <p class="text-muted mx-auto mt-2 max-w-xl">
              Train with Agora's Skill Mastery program, then apply to join the team.
            </p>
            <div class="mt-5 flex flex-wrap justify-center gap-3">
              <Button href={skillMasteryUrl} external size="lg">
                Explore Skill Mastery
              </Button>
              <Button href={cta.joinTeam.href} external variant="secondary" size="lg">
                {cta.joinTeam.label}
              </Button>
            </div>
          </>
        ) : (
          <>
            <h2 class="text-ink text-2xl font-bold">Want results like these for your business?</h2>
            <p class="text-muted mx-auto mt-2 max-w-xl">
              We turn analytics into growth. Let's talk about where you want to go.
            </p>
            <div class="mt-5 flex justify-center">
              <Button href={cta.becomeClient.href} external variant="icon" size="lg">
                {cta.becomeClient.label}
              </Button>
            </div>
          </>
        )
      }
    </div>

    {/* Cross-link to sibling silos */}
    {
      siblings.length > 0 && (
        <div class="mt-12">
          <p class="eyebrow">Explore more topics</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {siblings.map((s) => (
              <a
                href={`/blog/category/${s.slug}/`}
                class="border-line text-body hover:border-brand-300 hover:text-brand-700 rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
              >
                {s.name}
              </a>
            ))}
            <a
              href="/blog/"
              class="border-line text-body hover:border-brand-300 hover:text-brand-700 rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
            >
              All articles
            </a>
          </div>
        </div>
      )
    }
  </Container>
</BaseLayout>
