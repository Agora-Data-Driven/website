---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import { getCollection } from 'astro:content';
import { silos } from '@data/categories';

export const prerender = true;

// Blog silos only — case studies live under Portfolio (type: 'case-study').
const posts = (
  await getCollection('posts', ({ data }) => !data.draft && data.type === 'post')
).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Filter chips, in canonical silo order, only for silos that have posts.
const populated = new Set(posts.map((p) => p.data.category));
const chips = silos.filter((s) => populated.has(s.name));
---

<BaseLayout
  title="Blog"
  description="Insights on data-driven marketing, analytics, and growth from Agora Data Driven."
>
  <section class="border-line from-tint/40 to-canvas border-b bg-linear-to-b">
    <Container class="py-16 lg:py-20">
      <p class="eyebrow">Blog</p>
      <h1 class="text-ink mt-2 text-4xl font-bold sm:text-5xl">Latest from the blog</h1>
      <p class="text-muted mt-3 max-w-2xl">
        Practical insights on analytics-powered marketing, full-funnel growth, and what actually
        moves the needle.
      </p>
    </Container>
  </section>

  <Container class="py-12 lg:py-16">
    {/* Controls: search (JS-enhanced) + category filter (crawlable links) */}
    <div class="mb-10 flex flex-col gap-5">
      <div id="blog-search-wrap" hidden class="max-w-md">
        <label for="blog-search" class="sr-only">Search articles</label>
        <input
          id="blog-search"
          type="search"
          placeholder="Search articles…"
          autocomplete="off"
          class="border-line bg-surface text-ink placeholder:text-muted focus:border-brand-400 w-full rounded-full border px-5 py-2.5 text-sm shadow-sm outline-none"
        />
      </div>

      <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by topic">
        <a href="/blog/" data-filter="all" class="chip chip-active">All</a>
        {
          chips.map((s) => (
            <a href={`/blog/category/${s.slug}/`} data-filter={s.name} class="chip">
              {s.name}
            </a>
          ))
        }
      </div>
    </div>

    <div id="post-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article
            class="post-card border-line bg-surface shadow-card card-hover flex flex-col rounded-2xl border p-6"
            data-category={post.data.category}
            data-search={`${post.data.title} ${post.data.excerpt} ${post.data.category}`.toLowerCase()}
          >
            <p class="text-brand-600 text-xs font-semibold tracking-wide uppercase">
              {post.data.category}
            </p>
            <h2 class="text-ink mt-2 text-lg font-semibold">
              <a href={`/${post.id}/`} class="hover:text-brand-700">
                {post.data.title}
              </a>
            </h2>
            <p class="text-muted mt-2 flex-1 text-sm">{post.data.excerpt}</p>
            <p class="text-muted mt-4 text-xs">{fmt(post.data.publishDate)}</p>
          </article>
        ))
      }
    </div>

    <p id="no-results" hidden class="text-muted py-12 text-center">
      No articles match your search. <button type="button" id="clear-filters" class="text-brand-600 hover:text-brand-700 font-semibold underline">Clear filters</button>
    </p>
  </Container>
</BaseLayout>

<style>
  .chip {
    border-radius: 9999px;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    color: var(--color-body);
    padding: 0.375rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
  }
  .chip:hover {
    border-color: var(--color-brand-300);
    color: var(--color-brand-700);
  }
  .chip-active,
  .chip-active:hover {
    background: var(--color-brand-500);
    border-color: var(--color-brand-500);
    color: #fff;
  }
</style>

<script>
  // Progressive enhancement: with JS off, the chips are plain links to each
  // crawlable /blog/category/<slug>/ page and the search box is hidden. With JS,
  // they filter the cards in place (no query-string URLs are minted).
  const grid = document.getElementById('post-grid');
  if (grid) {
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-card'));
    const chips = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-filter]'));
    const searchWrap = document.getElementById('blog-search-wrap');
    const search = document.getElementById('blog-search') as HTMLInputElement | null;
    const noResults = document.getElementById('no-results');
    const clearBtn = document.getElementById('clear-filters');

    if (searchWrap) searchWrap.hidden = false;

    let activeFilter = 'all';
    let query = '';

    const apply = () => {
      let shown = 0;
      for (const card of cards) {
        const matchCat = activeFilter === 'all' || card.dataset.category === activeFilter;
        const matchText = query === '' || (card.dataset.search ?? '').includes(query);
        const visible = matchCat && matchText;
        card.hidden = !visible;
        if (visible) shown++;
      }
      if (noResults) noResults.hidden = shown !== 0;
    };

    for (const chip of chips) {
      chip.addEventListener('click', (e) => {
        e.preventDefault();
        activeFilter = chip.dataset.filter ?? 'all';
        for (const c of chips) c.classList.toggle('chip-active', c === chip);
        apply();
      });
    }

    search?.addEventListener('input', () => {
      query = search.value.trim().toLowerCase();
      apply();
    });

    clearBtn?.addEventListener('click', () => {
      activeFilter = 'all';
      query = '';
      if (search) search.value = '';
      for (const c of chips) c.classList.toggle('chip-active', c.dataset.filter === 'all');
      apply();
    });
  }
</script>
