---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import PageAurora from '@components/PageAurora.astro';
import RelatedPosts from '@components/RelatedPosts.astro';
import { site } from '@data/site';
import { getSilo } from '@data/categories';
import { getCollection } from 'astro:content';
import { relatedPosts } from '@lib/posts';
import { isSsoAdmin } from '@lib/sso';
import { serverEnv } from '@lib/env';

interface Props {
  title: string;
  publishDate: Date;
  updatedDate?: Date;
  excerpt: string;
  heroImage?: string;
  heroAlt?: string;
  category?: string;
  type?: 'post' | 'case-study' | 'data-file';
  slug?: string;
}
const {
  title,
  publishDate,
  updatedDate,
  excerpt,
  category,
  heroImage,
  heroAlt,
  type = 'post',
  slug,
} = Astro.props;

// Single source of truth for "is this a site admin" — @lib/sso (which also
// honours the ADMIN_EMAILS allowlist). This layout used to carry its own copy.
const isAdmin = isSsoAdmin(Astro.request.headers.get('cookie'), serverEnv('SSO_SECRET'));
const postSlug = slug ?? Astro.url.pathname.replace(/^\/|\/$/g, '');

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = new URL(Astro.url.pathname, site.url).href;

const isCaseStudy = type === 'case-study';
const silo = category ? getSilo(category) : undefined;

// Breadcrumb trail: case studies sit under Portfolio; posts under their silo.
const crumbs = isCaseStudy
  ? [
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/agora-portfolio/' },
      { label: title },
    ]
  : [
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      ...(silo ? [{ label: silo.name, href: `/blog/category/${silo.slug}/` }] : []),
      { label: title },
    ];

// "Keep reading" row — same silo first, then same kind, then newest. Computed
// here (not per-page) so every article route gets it for free, including posts
// published later by the SEO pipeline.
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const self = allPosts.find((p) => p.id === postSlug);
const related = self ? relatedPosts(self, allPosts, 3) : [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  datePublished: publishDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  author: { '@type': 'Organization', name: site.name, url: site.url },
  publisher: { '@type': 'Organization', name: site.name, url: site.url },
  mainEntityOfPage: canonical,
};
---

<BaseLayout title={title} description={excerpt} type="article">
  {
    /* Soft variant: the light field is present but dialled well back, so body
      copy keeps its AA contrast and long-form reading stays comfortable. */
  }
  <PageAurora variant="soft" />

  <article data-edit-post={postSlug}>
    <Container size="narrow" class="pt-10 pb-6 lg:pt-12">
      <Breadcrumb items={crumbs} />
      {
        isCaseStudy ? (
          <p class="eyebrow mt-6">Case Study</p>
        ) : (
          silo && (
            <a
              href={`/blog/category/${silo.slug}/`}
              class="eyebrow hover:text-brand-700 mt-6 inline-block"
            >
              {silo.name}
            </a>
          )
        )
      }
      <h1 class="text-ink mt-3 text-4xl font-bold sm:text-5xl" data-edit-role="title">{title}</h1>
      <p class="text-muted mt-4 max-w-2xl text-lg leading-relaxed">{excerpt}</p>
      <p class="text-muted border-line mt-6 border-t pt-4 text-sm">
        <time datetime={publishDate.toISOString()}>{fmt(publishDate)}</time>{
          updatedDate ? ` · Updated ${fmt(updatedDate)}` : ''
        }
      </p>
    </Container>

    {
      (heroImage || isAdmin) && (
        <Container size="narrow" class="pb-6">
          <div class="relative">
            {heroImage ? (
              <img
                src={heroImage}
                alt={heroAlt ?? ''}
                width="1600"
                height="900"
                class="border-line bg-canvas shadow-pop aspect-video w-full rounded-2xl border object-cover"
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            ) : (
              isAdmin && (
                <div class="border-line bg-canvas text-muted flex aspect-video w-full items-center justify-center rounded-2xl border text-sm">
                  No hero image yet
                </div>
              )
            )}
            {isAdmin && (
              <button
                type="button"
                id="admin-hero-btn"
                class="text-ink absolute right-3 bottom-3 flex items-center gap-1.5 rounded-lg bg-white/90 px-3 py-1.5 text-xs font-semibold shadow backdrop-blur-sm hover:bg-white"
                title="Change hero image"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                  <circle cx="12" cy="13" r="4" />
                </svg>
                Change photo
              </button>
            )}
          </div>
        </Container>
      )
    }

    <Container size="narrow" class="pb-12">
      {
        /* The reading panel sits on top of the aurora with a near-opaque frosted
          surface, so the drifting green never competes with the body copy. */
      }
      <div class="reading-panel border-line rounded-2xl border px-5 py-7 sm:px-8 sm:py-9">
        <div class="prose" data-edit-role="body">
          <slot />
        </div>
      </div>
    </Container>

    {/* Internal link up to the topic pillar / back to Portfolio */}
    <Container size="narrow" class="pb-6">
      <div class="border-line mt-2 border-t pt-6">
        {
          isCaseStudy ? (
            <a
              href="/agora-portfolio/#case-studies"
              class="text-brand-600 hover:text-brand-700 text-sm font-semibold"
            >
              &larr; More case studies
            </a>
          ) : silo ? (
            <a
              href={`/blog/category/${silo.slug}/`}
              class="text-brand-600 hover:text-brand-700 text-sm font-semibold"
            >
              Explore more in {silo.name} <span aria-hidden="true">&rarr;</span>
            </a>
          ) : (
            <a href="/blog/" class="text-brand-600 hover:text-brand-700 text-sm font-semibold">
              &larr; All articles
            </a>
          )
        }
      </div>
    </Container>

    {/* Related reading, directly under the "Explore more in <silo>" link. */}
    <Container size="narrow" class="pb-14">
      <RelatedPosts posts={related} />
    </Container>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  {
    isAdmin && (
      <div
        id="admin-hero-modal"
        style="display:none;position:fixed;inset:0;z-index:50;background:rgba(0,0,0,0.5);align-items:center;justify-content:center;"
      >
        <div style="background:#fff;border-radius:16px;padding:28px;width:min(420px,90vw);box-shadow:0 20px 60px rgba(0,0,0,0.2);">
          <h3 style="margin:0 0 6px;font-size:16px;font-weight:800;">Change hero photo</h3>
          <p style="margin:0 0 18px;font-size:13px;color:#6B7280;">
            Upload a new image for <strong>{postSlug}</strong>. PNG, JPG, or WebP, under 5 MB.
          </p>
          <form id="admin-hero-form">
            <input type="hidden" name="slug" value={postSlug} />
            <input
              type="file"
              name="image"
              accept="image/png,image/jpeg,image/webp"
              required
              style="display:block;width:100%;margin-bottom:14px;font-size:13px;"
            />
            <div style="display:flex;gap:10px;justify-content:flex-end;">
              <button
                type="button"
                id="admin-hero-cancel"
                style="padding:9px 18px;border-radius:8px;border:1px solid #E7E8EE;font-size:13px;font-weight:600;cursor:pointer;background:#fff;"
              >
                Cancel
              </button>
              <button
                type="submit"
                id="admin-hero-submit"
                style="padding:9px 18px;border-radius:8px;border:0;background:#4FAB4A;color:#fff;font-size:13px;font-weight:700;cursor:pointer;"
              >
                Upload
              </button>
            </div>
            <p id="admin-hero-status" style="margin:12px 0 0;font-size:12px;color:#6B7280;" />
          </form>
        </div>
      </div>
    )
  }

  <script>
    (() => {
      const btn = document.getElementById('admin-hero-btn');
      const modal = document.getElementById('admin-hero-modal') as HTMLElement | null;
      const cancel = document.getElementById('admin-hero-cancel') as HTMLElement | null;
      const form = document.getElementById('admin-hero-form') as HTMLFormElement | null;
      const submit = document.getElementById('admin-hero-submit') as HTMLButtonElement | null;
      const status = document.getElementById('admin-hero-status') as HTMLElement | null;
      if (!btn || !modal || !cancel || !form || !submit || !status) return;
      btn.addEventListener('click', () => {
        modal.style.display = 'flex';
      });
      cancel.addEventListener('click', () => {
        modal.style.display = 'none';
      });
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.style.display = 'none';
      });
      const fileInput = form.querySelector('input[type="file"]') as HTMLInputElement | null;
      const fail = (msg: string): void => {
        status.style.color = '#E5413E';
        status.textContent = msg;
      };
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        // Validate client-side first: an oversized screenshot or wrong file type is by far the most
        // common cause of a failed upload, and catching it here gives a clear reason immediately
        // instead of a round trip that surfaces as a generic "Network error".
        const file = fileInput?.files?.[0];
        if (!file) return fail('Please choose an image first.');
        if (file.type && !/^image\/(png|jpe?g|webp)$/.test(file.type))
          return fail('Please choose a PNG, JPG, or WebP image.');
        if (file.size > 5 * 1024 * 1024)
          return fail(
            `That image is ${(file.size / 1048576).toFixed(1)} MB — please use one under 5 MB.`,
          );

        submit.disabled = true;
        submit.textContent = 'Uploading...';
        status.style.color = '#6B7280';
        status.textContent = 'Uploading and publishing…';
        fetch('/api/update-hero', { method: 'POST', body: new FormData(form) })
          .then(async (r) => {
            // Tolerate a non-JSON body (e.g. a 5xx HTML page from Cloud Run while a prior save's
            // deploy is rolling out) so the message is actionable rather than blank.
            const text = await r.text().catch(() => '');
            let res: { ok?: boolean; error?: string } = {};
            try {
              res = JSON.parse(text) as typeof res;
            } catch {
              res = {
                ok: false,
                error:
                  r.status >= 500
                    ? `Server error (${r.status}). A publish may be in progress — wait a minute and try again.`
                    : `Unexpected response (${r.status}).`,
              };
            }
            if (r.ok && res.ok) {
              status.style.color = '#347A30';
              status.textContent = 'Saved. Reloading...';
              setTimeout(() => window.location.reload(), 1500);
            } else {
              fail(res.error || 'Upload failed.');
              submit.disabled = false;
              submit.textContent = 'Upload';
            }
          })
          .catch(() => {
            fail('Couldn’t reach the server. Check your connection and try again.');
            submit.disabled = false;
            submit.textContent = 'Upload';
          });
      });
    })();
  </script>
</BaseLayout>

<style>
  /* Reading surface. Deliberately near-opaque (94%): the page aurora should be
     felt at the margins, never read through the body copy. `backdrop-filter`
     softens whatever drifts behind it so text contrast stays constant as the
     blobs move. */
  .reading-panel {
    background: color-mix(in srgb, var(--color-surface) 94%, transparent);
    backdrop-filter: blur(14px) saturate(1.05);
    -webkit-backdrop-filter: blur(14px) saturate(1.05);
    box-shadow: var(--shadow-card);
  }
</style>
