---
import '@fontsource-variable/archivo';
import '@fontsource/lato/400.css';
import '@fontsource/lato/700.css';
// The two faces that paint above-the-fold text (the h1 is Archivo, body copy is
// Lato 400). Without a preload they're only discovered after the ~97 KB
// render-blocking stylesheet parses, so the hero paints in a fallback face and
// then visibly swaps. Vite emits the same hashed asset the @font-face rules
// point at, so this preloads the real file rather than fetching a second copy.
import archivoLatinUrl from '@fontsource-variable/archivo/files/archivo-latin-wght-normal.woff2?url';
import latoLatin400Url from '@fontsource/lato/files/lato-latin-400-normal.woff2?url';
import '../styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SEO from '@components/SEO.astro';
import AdminEditor from '@components/AdminEditor.astro';
import { site } from '@data/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}
const { title, description, canonical, ogImage, type, noindex } = Astro.props;

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  description: site.description,
  sameAs: ['https://www.upwork.com/agencies/1818954484693860352/'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={archivoLatinUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={latoLatin400Url} as="font" type="font/woff2" crossorigin />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f7f7f8" />
    <!-- Favicons. Agora mark as the primary icon across browsers +
         Apple touch icon; webmanifest for installable/PWA metadata. -->
    <link rel="icon" href="/FAVI.png" type="image/png" sizes="any" />
    <link rel="shortcut icon" href="/FAVI.png" type="image/png" />
    <link rel="apple-touch-icon" href="/FAVI.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      type={type}
      noindex={noindex}
    />
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <noscript
      ><style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style></noscript
    >
  </head>
  <body class="flex min-h-dvh flex-col">
    <a
      href="#main"
      class="focus:bg-ink sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <AdminEditor />

    <script>
      // Scroll-reveal: fade/slide elements in as they enter the viewport.
      // Tiny, one-shot per element; respects reduced-motion and old browsers.
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>


  </body>
</html>
