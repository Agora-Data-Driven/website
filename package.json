{
  "name": "agora-data-driven",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "deploy": "gcloud run deploy agora-data-driven --source . --project agora-data-driven --region australia-southeast1 --allow-unauthenticated --quiet"
  },
  "dependencies": {
    "@astrojs/mdx": "^4",
    "@astrojs/node": "^9",
    "@astrojs/sitemap": "^3",
    "@fontsource-variable/inter": "^5",
    "astro": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
